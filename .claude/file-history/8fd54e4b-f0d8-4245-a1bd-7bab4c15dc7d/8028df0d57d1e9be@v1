<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Clínica — Nome da Clínica</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    /* ============================================
       VARIÁVEIS — edite aqui para mudar as cores
    ============================================ */
    :root {
      --cor-primaria: #c9a97a;        /* dourado/rose gold */
      --cor-primaria-escura: #a8875a;
      --cor-texto: #3a3a3a;
      --cor-texto-claro: #7a7a7a;
      --cor-fundo: #fdfaf7;
      --cor-fundo-secao: #f9f3ee;
      --cor-branco: #ffffff;
      --cor-rosa-claro: #f5ede4;
      --fonte-titulo: 'Cormorant Garamond', serif;
      --fonte-corpo: 'Jost', sans-serif;
    }

    /* ============================================
       RESET & BASE
    ============================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--fonte-corpo);
      color: var(--cor-texto);
      background: var(--cor-fundo);
      font-size: 16px;
      line-height: 1.7;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }

    /* ============================================
       UTILITÁRIOS
    ============================================ */
    .container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    .section-tag {
      font-family: var(--fonte-corpo);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--cor-primaria);
      display: block;
      margin-bottom: 12px;
    }
    .section-title {
      font-family: var(--fonte-titulo);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 300;
      line-height: 1.2;
      color: var(--cor-texto);
    }
    .section-title em {
      font-style: italic;
      color: var(--cor-primaria);
    }
    .btn {
      display: inline-block;
      padding: 14px 36px;
      font-family: var(--fonte-corpo);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      border: 1.5px solid var(--cor-primaria);
      color: var(--cor-primaria);
      transition: all 0.3s ease;
      cursor: pointer;
    }
    .btn:hover {
      background: var(--cor-primaria);
      color: var(--cor-branco);
    }
    .btn-filled {
      background: var(--cor-primaria);
      color: var(--cor-branco);
    }
    .btn-filled:hover {
      background: var(--cor-primaria-escura);
      border-color: var(--cor-primaria-escura);
    }
    .divider {
      width: 50px;
      height: 1.5px;
      background: var(--cor-primaria);
      margin: 20px 0;
    }

    /* ============================================
       HEADER / NAVEGAÇÃO
    ============================================ */
    .header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      background: rgba(253, 250, 247, 0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid rgba(201,169,122,0.2);
      transition: box-shadow 0.3s;
    }
    .header.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.06); }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 80px;
    }
    .logo {
      font-family: var(--fonte-titulo);
      font-size: 1.6rem;
      font-weight: 300;
      letter-spacing: 1px;
      color: var(--cor-texto);
    }
    .logo span { color: var(--cor-primaria); }
    /* Substitua o texto do logo por uma tag <img> com seu logo real */

    .nav { display: flex; align-items: center; gap: 36px; }
    .nav a {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--cor-texto);
      position: relative;
      transition: color 0.2s;
    }
    .nav a::after {
      content: '';
      position: absolute;
      bottom: -4px; left: 0;
      width: 0; height: 1px;
      background: var(--cor-primaria);
      transition: width 0.3s;
    }
    .nav a:hover { color: var(--cor-primaria); }
    .nav a:hover::after { width: 100%; }

    /* Dropdown procedimentos */
    .nav-dropdown { position: relative; }
    .nav-dropdown > a::after { display: none; }
    .dropdown-menu {
      position: absolute;
      top: calc(100% + 20px);
      left: -20px;
      background: var(--cor-branco);
      border: 1px solid rgba(201,169,122,0.2);
      box-shadow: 0 8px 40px rgba(0,0,0,0.08);
      min-width: 260px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: all 0.25s ease;
      z-index: 999;
    }
    .nav-dropdown:hover .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .dropdown-col { padding: 24px; }
    .dropdown-col h4 {
      font-family: var(--fonte-corpo);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--cor-primaria);
      margin-bottom: 12px;
    }
    .dropdown-col a {
      display: block;
      font-size: 13px;
      letter-spacing: 0;
      text-transform: none;
      font-weight: 300;
      padding: 5px 0;
      color: var(--cor-texto);
      border-bottom: none;
      transition: color 0.2s, padding-left 0.2s;
    }
    .dropdown-col a:hover { color: var(--cor-primaria); padding-left: 6px; }
    .dropdown-col a::after { display: none !important; }

    .nav-cta {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 10px 22px;
      background: var(--cor-primaria);
      color: var(--cor-branco) !important;
      transition: background 0.3s !important;
    }
    .nav-cta:hover { background: var(--cor-primaria-escura) !important; color: var(--cor-branco) !important; }
    .nav-cta::after { display: none !important; }

    /* Menu Mobile */
    .menu-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px;
    }
    .menu-toggle span {
      display: block;
      width: 24px;
      height: 1.5px;
      background: var(--cor-texto);
      transition: all 0.3s;
    }

    /* ============================================
       HERO BANNER
    ============================================ */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, #fdf8f3 0%, #f9f0e6 50%, #f5e8d8 100%);
      padding-top: 80px;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -100px; right: -100px;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(201,169,122,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 60px;
      min-height: calc(100vh - 80px);
    }
    .hero-content { padding: 80px 0; }
    .hero-eyebrow {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--cor-primaria);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .hero-eyebrow::before {
      content: '';
      width: 40px;
      height: 1px;
      background: var(--cor-primaria);
    }
    .hero-title {
      font-family: var(--fonte-titulo);
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 300;
      line-height: 1.1;
      margin-bottom: 24px;
      color: var(--cor-texto);
    }
    .hero-title em {
      font-style: italic;
      color: var(--cor-primaria);
      display: block;
    }
    .hero-subtitle {
      font-size: 15px;
      font-weight: 300;
      color: var(--cor-texto-claro);
      max-width: 420px;
      margin-bottom: 40px;
      line-height: 1.8;
    }
    .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
    .hero-image {
      position: relative;
      height: 100%;
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }
    .hero-image-frame {
      position: relative;
      width: 100%;
      max-width: 500px;
    }
    .hero-img-placeholder {
      width: 100%;
      aspect-ratio: 3/4;
      background: linear-gradient(160deg, #e8d5c0 0%, #d4b896 100%);
      border-radius: 2px 60px 2px 60px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.7);
      font-family: var(--fonte-titulo);
      font-size: 1rem;
      letter-spacing: 2px;
      text-align: center;
      gap: 8px;
      position: relative;
      overflow: hidden;
    }
    /* Quando tiver a foto real, substitua .hero-img-placeholder por <img> */
    .hero-img-placeholder svg { width: 48px; opacity: 0.5; }
    .hero-badge {
      position: absolute;
      bottom: 40px;
      left: -20px;
      background: var(--cor-branco);
      border: 1px solid rgba(201,169,122,0.3);
      padding: 16px 24px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    }
    .hero-badge-num {
      font-family: var(--fonte-titulo);
      font-size: 2.2rem;
      font-weight: 300;
      color: var(--cor-primaria);
      line-height: 1;
    }
    .hero-badge-txt {
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--cor-texto-claro);
      margin-top: 4px;
    }
    .hero-deco {
      position: absolute;
      top: 30px; right: -10px;
      width: 120px; height: 120px;
      border: 1px solid rgba(201,169,122,0.25);
      border-radius: 50%;
    }

    /* ============================================
       PROCEDIMENTOS
    ============================================ */
    .procedimentos {
      padding: 100px 0;
      background: var(--cor-fundo);
    }
    .procedimentos-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 60px;
      gap: 40px;
      flex-wrap: wrap;
    }
    .procedimentos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 24px;
    }
    .proc-card {
      background: var(--cor-branco);
      border: 1px solid rgba(201,169,122,0.15);
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
      cursor: pointer;
    }
    .proc-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 50px rgba(0,0,0,0.08);
    }
    .proc-card-img {
      aspect-ratio: 4/3;
      background: linear-gradient(145deg, var(--cor-rosa-claro), #e8d5c0);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }
    .proc-card-img img { width: 100%; height: 100%; object-fit: cover; }
    .proc-card-img-placeholder {
      font-family: var(--fonte-titulo);
      font-style: italic;
      font-size: 0.85rem;
      color: rgba(120,90,60,0.4);
      letter-spacing: 1px;
    }
    .proc-card-body { padding: 24px 20px; }
    .proc-card-body h3 {
      font-family: var(--fonte-titulo);
      font-size: 1.2rem;
      font-weight: 400;
      line-height: 1.3;
      margin-bottom: 8px;
    }
    .proc-card-body p {
      font-size: 13px;
      font-weight: 300;
      color: var(--cor-texto-claro);
      margin-bottom: 16px;
      line-height: 1.6;
    }
    .proc-card-link {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--cor-primaria);
      display: flex;
      align-items: center;
      gap: 8px;
      transition: gap 0.2s;
    }
    .proc-card-link:hover { gap: 14px; }
    .proc-card-link::after { content: '→'; }

    /* Tabs de procedimentos */
    .proc-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 40px;
      flex-wrap: wrap;
    }
    .proc-tab {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 10px 24px;
      border: 1px solid rgba(201,169,122,0.3);
      color: var(--cor-texto-claro);
      cursor: pointer;
      transition: all 0.2s;
      background: transparent;
      font-family: var(--fonte-corpo);
    }
    .proc-tab.active, .proc-tab:hover {
      background: var(--cor-primaria);
      color: var(--cor-branco);
      border-color: var(--cor-primaria);
    }
    .proc-panel { display: none; }
    .proc-panel.active { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; }

    /* ============================================
       SOBRE A CLÍNICA
    ============================================ */
    .sobre {
      padding: 100px 0;
      background: var(--cor-fundo-secao);
    }
    .sobre-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .sobre-image { position: relative; }
    .sobre-img-frame {
      width: 100%;
      aspect-ratio: 3/4;
      background: linear-gradient(160deg, #e0cbb5 0%, #c9a97a 100%);
      border-radius: 60px 2px 60px 2px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.5);
      font-family: var(--fonte-titulo);
      font-style: italic;
    }
    .sobre-deco {
      position: absolute;
      bottom: -20px; right: -20px;
      width: 200px; height: 200px;
      border: 1px solid rgba(201,169,122,0.3);
      border-radius: 50%;
      z-index: -1;
    }
    .sobre-deco-2 {
      position: absolute;
      top: -15px; left: -15px;
      width: 80px; height: 80px;
      background: var(--cor-rosa-claro);
      border-radius: 50%;
      z-index: -1;
    }
    .sobre-content { padding: 20px 0; }
    .sobre-content p {
      font-size: 15px;
      font-weight: 300;
      color: var(--cor-texto-claro);
      line-height: 1.9;
      margin-bottom: 20px;
    }
    .sobre-content strong { color: var(--cor-texto); font-weight: 500; }

    /* Pilares */
    .pilares {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 36px 0;
    }
    .pilar {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 16px;
      background: var(--cor-branco);
      border: 1px solid rgba(201,169,122,0.15);
    }
    .pilar-icon {
      width: 40px;
      height: 40px;
      background: var(--cor-rosa-claro);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 18px;
    }
    .pilar-text {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.5px;
      color: var(--cor-texto);
    }

    /* ============================================
       DEPOIMENTOS / FAMOSOS
    ============================================ */
    .depoimentos {
      padding: 100px 0;
      background: var(--cor-fundo);
      overflow: hidden;
    }
    .depoimentos-header { text-align: center; margin-bottom: 60px; }
    .depoimentos-header .divider { margin: 20px auto; }
    .depoimentos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
    }
    .dep-card {
      position: relative;
      overflow: hidden;
      border-radius: 2px;
      cursor: pointer;
    }
    .dep-card-img {
      aspect-ratio: 4/5;
      background: linear-gradient(145deg, #e8d5c0, #d4b896);
      overflow: hidden;
      position: relative;
    }
    .dep-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
    .dep-card:hover .dep-card-img img { transform: scale(1.05); }
    .dep-card-overlay {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
      padding: 30px 16px 16px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .dep-card:hover .dep-card-overlay { opacity: 1; }
    .dep-card-handle {
      color: var(--cor-branco);
      font-size: 13px;
      font-weight: 400;
    }
    .dep-card-label {
      position: absolute;
      bottom: 12px;
      left: 12px;
      background: rgba(255,255,255,0.9);
      padding: 6px 12px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 1px;
      color: var(--cor-texto);
    }
    .dep-img-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--fonte-titulo);
      font-style: italic;
      color: rgba(120,80,40,0.35);
      font-size: 0.9rem;
    }

    /* ============================================
       INSTAGRAM / FEED
    ============================================ */
    .instagram {
      padding: 100px 0;
      background: var(--cor-fundo-secao);
      text-align: center;
    }
    .instagram-handle {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .instagram-handle svg { width: 28px; }
    .instagram-handle a {
      font-family: var(--fonte-titulo);
      font-size: 1.8rem;
      font-weight: 300;
      color: var(--cor-texto);
      transition: color 0.2s;
    }
    .instagram-handle a:hover { color: var(--cor-primaria); }
    .instagram-sub {
      font-size: 12px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--cor-texto-claro);
      margin-bottom: 48px;
    }
    .instagram-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 40px;
    }
    .insta-post {
      aspect-ratio: 1;
      background: linear-gradient(145deg, var(--cor-rosa-claro), #e0cbb5);
      overflow: hidden;
      position: relative;
      cursor: pointer;
    }
    .insta-post img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
    .insta-post:hover img { transform: scale(1.06); }
    .insta-post-overlay {
      position: absolute;
      inset: 0;
      background: rgba(201,169,122,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .insta-post:hover .insta-post-overlay { opacity: 1; }
    .insta-post-overlay svg { width: 32px; fill: white; }
    .insta-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      letter-spacing: 1px;
      color: rgba(120,80,40,0.3);
      font-family: var(--fonte-corpo);
    }

    /* ============================================
       LOCALIZAÇÃO
    ============================================ */
    .localizacao {
      padding: 100px 0;
      background: var(--cor-fundo);
    }
    .localizacao-inner {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 60px;
      align-items: center;
    }
    .localizacao-info { }
    .localizacao-info p {
      font-size: 15px;
      font-weight: 300;
      color: var(--cor-texto-claro);
      margin-bottom: 12px;
    }
    .localizacao-info strong { color: var(--cor-texto); }
    .contact-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 18px 0;
      border-bottom: 1px solid rgba(201,169,122,0.15);
    }
    .contact-item:first-of-type { border-top: 1px solid rgba(201,169,122,0.15); margin-top: 32px; }
    .contact-icon {
      width: 44px; height: 44px;
      background: var(--cor-rosa-claro);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 18px;
    }
    .contact-label { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--cor-texto-claro); }
    .contact-value { font-size: 14px; font-weight: 400; color: var(--cor-texto); margin-top: 2px; }
    .mapa-placeholder {
      width: 100%;
      aspect-ratio: 4/3;
      background: #ede4d8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--fonte-titulo);
      font-style: italic;
      color: rgba(120,80,40,0.4);
      font-size: 1rem;
      letter-spacing: 1px;
    }
    /* Para inserir Google Maps real, substitua .mapa-placeholder por <iframe> */

    /* ============================================
       NEWSLETTER
    ============================================ */
    .newsletter {
      padding: 80px 0;
      background: linear-gradient(135deg, #3a2e25 0%, #5a4535 100%);
      position: relative;
      overflow: hidden;
    }
    .newsletter::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 350px; height: 350px;
      border-radius: 50%;
      background: rgba(201,169,122,0.1);
      pointer-events: none;
    }
    .newsletter-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      flex-wrap: wrap;
    }
    .newsletter-text .section-tag { color: var(--cor-primaria); }
    .newsletter-text .section-title { color: var(--cor-branco); }
    .newsletter-text p {
      color: rgba(255,255,255,0.6);
      font-size: 14px;
