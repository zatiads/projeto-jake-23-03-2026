    if (chartMilhao) chartMilhao.destroy();
    chartMilhao = new Chart(canvas, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Patrimônio',
          data: pontos,
          borderColor: '#00e5ff',
