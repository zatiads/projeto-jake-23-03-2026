  // ── UTILITÁRIOS ────────────────────────────────────────────────────────────
  function fmt(v) {
    return 'R$ ' + Math.abs(v).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function fmtK(v) {
    if (Math.abs(v) >= 1000000) return 'R$ ' + (v/1000000).toFixed(2).replace('.',',') + 'M';
    if (Math.abs(v) >= 1000)    return 'R$ ' + (v/1000).toFixed(1).replace('.',',') + 'K';
    return fmt(v);
  }
  function mesLabel(mes, ano) {
    var n = ['','Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
    return n[mes] + ' ' + ano;
  }
  function transacoesDo(mes, ano) {
    var y = String(ano), m = String(mes).padStart(2,'0');
    return TRANSACOES.filter(function(t){ return t.data.startsWith(y+'-'+m); });
  }
  function calcularKPIs(mes, ano) {
    var lista    = transacoesDo(mes, ano);
    var receita  = lista.filter(function(t){ return t.tipo==='Entrada'; }).reduce(function(s,t){ return s+t.valor; },0);
    var despesas = lista.filter(function(t){ return t.tipo==='Saída';   }).reduce(function(s,t){ return s+t.valor; },0);
    return { receita:receita, despesas:despesas, saldo:receita-despesas };
  }

  // ── RAIO-X: somatórios ─────────────────────────────────────────────────────
  function raixoSomaLinha(itens, mes) {
    return itens.reduce(function(s,item){ return s + (item.v[mes] || 0); }, 0);
  }
  function raixoTotaisMensais() {
    var totais = { receitas:[], fixas:[], variaveis:[], saldo:[], acumulado:[] };
    var acum = 0;
    for (var m = 0; m < 12; m++) {
      var r = raixoSomaLinha(RAIOX.entradas, m);
      var f = raixoSomaLinha(RAIOX.fixas, m);
      var v = raixoSomaLinha(RAIOX.variaveis, m);
      var s = r - f - v;
      acum += s;
      totais.receitas.push(r);
      totais.fixas.push(f);
      totais.variaveis.push(v);
      totais.saldo.push(s);
      totais.acumulado.push(acum);
    }
    return totais;
  }

