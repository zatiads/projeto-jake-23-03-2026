            <button class="fin-tab-btn" data-tab="projecoes">
              <span>◉</span> Projeções
            </button>
            <button class="fin-tab-btn fin-tab-milhao" data-tab="milhao">
              <span>⬡</span> Projeto 1 Milhão
            </button>
          </div>

          <!-- ═══════════════════════════════════════════
               ABA 1: VISÃO GERAL
          ════════════════════════════════════════════ -->
          <div class="fin-tab-pane active" id="fin-pane-visao-geral">

            <!-- Toolbar / Filtro de mês -->
            <div class="fin-visao-toolbar">
              <div class="fin-mes-filter">
                <span class="fin-mes-filter-label">Mês de análise</span>
                <div class="fin-mes-filter-controls">
                  <select id="fin-visao-mes" class="fin-select">
                    <option value="1">Jan/2026</option>
                    <option value="2">Fev/2026</option>
                    <option value="3">Mar/2026</option>
                    <option value="4">Abr/2026</option>
                    <option value="5">Mai/2026</option>
                    <option value="6">Jun/2026</option>
                    <option value="7">Jul/2026</option>
                    <option value="8">Ago/2026</option>
                    <option value="9">Set/2026</option>
                    <option value="10">Out/2026</option>
                    <option value="11">Nov/2026</option>
                    <option value="12">Dez/2026</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- KPI Cards -->
            <div class="fin-kpi-row">
              <div class="fin-kpi-card fin-kpi-receita">
                <span class="fin-kpi-icon">↑</span>
                <span class="fin-kpi-label">Receitas do Mês</span>
                <span class="fin-kpi-value fin-val-positive" id="fin-kpi-receita">R$ --</span>
                <span class="fin-kpi-sub" id="fin-kpi-receita-mes">--</span>
              </div>
              <div class="fin-kpi-card fin-kpi-despesas">
                <span class="fin-kpi-icon">↓</span>
                <span class="fin-kpi-label">Despesas do Mês</span>
                <span class="fin-kpi-value fin-val-negative" id="fin-kpi-despesas">R$ --</span>
                <span class="fin-kpi-sub">Fixas + Variáveis</span>
              </div>
              <div class="fin-kpi-card fin-kpi-saldo">
                <span class="fin-kpi-icon">⚖</span>
                <span class="fin-kpi-label">Saldo do Mês</span>
                <span class="fin-kpi-value" id="fin-kpi-saldo">R$ --</span>
                <span class="fin-kpi-sub">Receitas − Despesas</span>
              </div>
              <div class="fin-kpi-card fin-kpi-projecao">
                <span class="fin-kpi-icon">◈</span>
                <span class="fin-kpi-label">Acumulado Anual</span>
                <span class="fin-kpi-value" id="fin-kpi-projecao">R$ --</span>
                <span class="fin-kpi-sub">Jan → mês atual</span>
              </div>
            </div>

            <!-- Gráficos -->
            <div class="fin-charts-row">
              <div class="fin-chart-card fin-chart-barras-card">
                <h3 class="fin-chart-title">Receitas vs Despesas — Últimos 4 Meses</h3>
                <div class="fin-chart-wrap">
                  <canvas id="fin-chart-barras"></canvas>
                </div>
              </div>
              <div class="fin-chart-card fin-chart-donut-card">
                <h3 class="fin-chart-title">Divisão de Despesas</h3>
                <div class="fin-chart-wrap">
                  <canvas id="fin-chart-donut"></canvas>
                </div>
              </div>
            </div>

            <!-- Análise de IA -->
            <div class="fin-ai-section">
              <button class="fin-ai-btn" id="fin-ai-btn">
                <span class="fin-ai-btn-icon">✦</span>
                Gerar Análise Financeira com IA
              </button>
              <div class="fin-ai-result hidden" id="fin-ai-result">
                <div class="fin-ai-loading" id="fin-ai-loading">
                  <div class="fin-ai-dots"><span></span><span></span><span></span></div>
                  <p>Jake está analisando suas finanças...</p>
                </div>
                <div class="fin-ai-text hidden" id="fin-ai-text"></div>
              </div>
            </div>

            <!-- ── Raio-X: Planilha Anual ────────────── -->
            <div class="fin-raiox-section">
              <div class="fin-raiox-header">
                <h3 class="fin-section-title">◈ Raio-X — Planilha Anual 2026 <span class="fin-raiox-status" id="fin-raiox-status"></span></h3>
                <p class="fin-raiox-sub">Linha por linha, mês a mês — meses futuros calculados pelos recorrentes</p>
              </div>
              <div class="fin-raiox-scroll-top" id="fin-raiox-scroll-top">
                <div class="fin-raiox-scroll-top-inner" id="fin-raiox-scroll-top-inner"></div>
              </div>
              <div class="fin-raiox-scroll" id="fin-raiox-scroll">
                <table class="fin-raiox-table" id="fin-raiox-table">
                  <!-- populado por financeiro.js -->
                </table>
              </div>
            </div>

          </div><!-- /#fin-pane-visao-geral -->

          <!-- ═══════════════════════════════════════════
               ABA 2: LANÇAMENTOS
          ════════════════════════════════════════════ -->
          <div class="fin-tab-pane" id="fin-pane-lancamentos">

            <!-- Formulário Rápido -->
            <div class="fin-form-card">
              <h3 class="fin-form-title">✦ Novo Lançamento</h3>
              <div class="fin-form-grid">

                <div class="fin-form-field fin-field-desc">
                  <label class="fin-label">Descrição</label>
                  <input type="text" id="fin-desc" class="fin-input" placeholder="Ex: Aluguel, Piloti…">
                </div>

                <div class="fin-form-field">
                  <label class="fin-label">Valor (R$)</label>
                  <input type="number" id="fin-valor" class="fin-input" placeholder="0,00" step="0.01" min="0">
                </div>

                <div class="fin-form-field">
                  <label class="fin-label">Data</label>
                  <input type="date" id="fin-data" class="fin-input">
                </div>

                <div class="fin-form-field">
                  <label class="fin-label">Tipo</label>
                  <div class="fin-select-wrap">
                    <select id="fin-tipo" class="fin-select">
                      <option value="Entrada">↑ Entrada</option>
                      <option value="Saída">↓ Saída</option>
                    </select>
                    <span class="fin-select-arrow">▾</span>
                  </div>
                </div>

                <div class="fin-form-field">
                  <label class="fin-label">Categoria</label>
                  <div class="fin-select-wrap">
                    <select id="fin-categoria" class="fin-select">
                      <option value="Fixa">Fixa</option>
                      <option value="Variável">Variável</option>
                    </select>
                    <span class="fin-select-arrow">▾</span>
                  </div>
                </div>

                <div class="fin-form-field fin-field-check">
                  <label class="fin-label">&nbsp;</label>
                  <label class="fin-toggle-wrap">
                    <input type="checkbox" id="fin-recorrente" class="fin-toggle-input">
                    <span class="fin-toggle-slider"></span>
                    <span class="fin-toggle-text">Recorrente</span>
                  </label>
                </div>

              </div>
              <div class="fin-form-footer">
                <button class="fin-add-btn" id="fin-add-btn">
                  <span>+</span> Adicionar Lançamento
                </button>
                <div id="fin-flash" class="fin-flash hidden"></div>
              </div>
            </div>

            <!-- Tabela de Transações -->
            <div class="fin-table-card">
              <div class="fin-table-header">
                <h3 class="fin-table-title">Movimentações do Mês</h3>
                <div class="fin-mes-nav">
                  <button class="fin-mes-btn" id="fin-mes-prev">‹</button>
                  <span class="fin-mes-label" id="fin-mes-label">Fevereiro 2026</span>
                  <button class="fin-mes-btn" id="fin-mes-next">›</button>
                </div>
              </div>
              <div class="fin-table-scroll">
                <table class="fin-table">
                  <thead>
                    <tr>
                      <th>Data</th>
                      <th>Descrição</th>
                      <th>Categoria</th>
                      <th>Tipo</th>
                      <th>Valor</th>
                      <th>–</th>
                    </tr>
                  </thead>
                  <tbody id="fin-tbody">
                    <!-- populado por financeiro.js -->
                  </tbody>
                </table>
              </div>
            </div>

          </div><!-- /#fin-pane-lancamentos -->

          <!-- ═══════════════════════════════════════════
               ABA 3: PROJEÇÕES
          ════════════════════════════════════════════ -->
          <div class="fin-tab-pane" id="fin-pane-projecoes">

            <!-- Card Acumulado Destaque -->
            <div class="fin-acum-destaque">
              <div class="fin-acum-destaque-inner">
                <span class="fin-acum-icon">◈</span>
                <div>
                  <p class="fin-acum-label">Acumulado Previsto em Dez/2026</p>
                  <p class="fin-acum-valor" id="fin-acum-dez">R$ --</p>
                </div>
              </div>
              <div class="fin-acum-chips">
                <span class="fin-acum-chip fin-chip-g">Receitas anuais: <strong id="fin-chip-receita">--</strong></span>
                <span class="fin-acum-chip fin-chip-r">Despesas anuais: <strong id="fin-chip-despesa">--</strong></span>
                <span class="fin-acum-chip fin-chip-b">Saldo anual: <strong id="fin-chip-saldo">--</strong></span>
              </div>
            </div>

            <!-- Gráfico de Linhas Anual -->
            <div class="fin-chart-card fin-chart-linha-card">
              <h3 class="fin-chart-title">Fluxo de Caixa — Jan a Dez/2026</h3>
              <div class="fin-chart-wrap" style="height:280px;">
                <canvas id="fin-chart-linha"></canvas>
              </div>
            </div>

            <!-- Cards próximos 3 meses -->
            <div class="fin-proj-header">
              <h3 class="fin-proj-title">Próximos 3 Meses (Itens Recorrentes)</h3>
              <p class="fin-proj-sub">Apenas itens marcados como <span class="cyan">Recorrente</span> — previsibilidade de caixa fixo</p>
            </div>
            <div class="fin-proj-grid" id="fin-proj-grid">
              <!-- populado por financeiro.js -->
            </div>

          </div><!-- /#fin-pane-projecoes -->

          <!-- ═══════════════════════════════════════════
               ABA 4: PROJETO 1 MILHÃO
          ════════════════════════════════════════════ -->
          <div class="fin-tab-pane" id="fin-pane-milhao">

            <div class="fin-milhao-layout">

              <!-- Painel Esquerdo: Inputs -->
              <div class="fin-milhao-inputs">
                <div class="fin-milhao-inputs-header">
                  <span class="fin-milhao-hicon">⬡</span>
                  <div>
                    <h3 class="fin-milhao-htitle">Calculadora do <span class="cyan">Milhão</span></h3>
                    <p class="fin-milhao-hsub">Juros compostos · Independência financeira</p>
                  </div>
                </div>

                <div class="fin-milhao-field">
                  <label class="fin-milhao-label">Aporte Mensal (R$)</label>
                  <input type="number" id="mil-aporte" class="fin-milhao-input" value="4500" step="100" min="0">
                  <span class="fin-milhao-hint">💡 Média da sua sobra mensal projetada</span>
                </div>

                <div class="fin-milhao-field">
                  <label class="fin-milhao-label">Patrimônio Atual Investido (R$)</label>
                  <input type="number" id="mil-patrimonio" class="fin-milhao-input" value="0" step="1000" min="0">
                </div>

                <div class="fin-milhao-field">
                  <label class="fin-milhao-label">Taxa de Rendimento Mensal (%)</label>
                  <div class="fin-milhao-taxa-row">
                    <input type="number" id="mil-taxa" class="fin-milhao-input" value="1.0" step="0.1" min="0.01" max="5">
                    <div class="fin-milhao-presets">
                      <button class="fin-preset-btn" data-taxa="0.8">CDI</button>
                      <button class="fin-preset-btn active" data-taxa="1.0">1%</button>
                      <button class="fin-preset-btn" data-taxa="1.2">FII</button>
                      <button class="fin-preset-btn" data-taxa="2.0">Cripto</button>
                    </div>
                  </div>
                </div>

                <div class="fin-milhao-field">
                  <label class="fin-milhao-label">Meta</label>
                  <div class="fin-milhao-meta-row">
                    <button class="fin-meta-btn active" data-meta="1000000">R$ 1M</button>
                    <button class="fin-meta-btn" data-meta="500000">R$ 500K</button>
                    <button class="fin-meta-btn" data-meta="2000000">R$ 2M</button>
                    <button class="fin-meta-btn" data-meta="5000000">R$ 5M</button>
                  </div>
                </div>

                <button class="fin-milhao-calc-btn" id="mil-calc-btn">
                  <span>⬡</span> Calcular Minha Riqueza
                </button>
              </div>

              <!-- Painel Direito: Resultado Jarvis -->
              <div class="fin-milhao-resultado" id="fin-milhao-resultado">

                <!-- Estado inicial -->
                <div class="fin-milhao-idle" id="mil-idle">
                  <div class="fin-milhao-orb"></div>
                  <p>Configure os parâmetros e calcule sua<br><strong>data da independência financeira</strong></p>
                </div>

                <!-- Resultado -->
                <div class="fin-milhao-display hidden" id="mil-display">

                  <div class="fin-milhao-meta-badge" id="mil-meta-badge">Meta: R$ 1.000.000</div>

                  <div class="fin-milhao-data-box">
                    <span class="fin-milhao-data-label">Data do Milhão</span>
                    <span class="fin-milhao-data-valor" id="mil-data">--/--/----</span>
                  </div>

                  <div class="fin-milhao-idade-box">
                    <span class="fin-milhao-data-label">Você terá</span>
                    <span class="fin-milhao-idade-valor" id="mil-idade">-- anos</span>
                  </div>

                  <!-- Barra de Progresso -->
                  <div class="fin-milhao-progress-wrap">
                    <div class="fin-milhao-progress-labels">
                      <span id="mil-prog-atual">R$ 0</span>
                      <span id="mil-prog-meta">R$ 1.000.000</span>
                    </div>
                    <div class="fin-milhao-progress-bar">
                      <div class="fin-milhao-progress-fill" id="mil-prog-fill" style="width:0%"></div>
                      <div class="fin-milhao-progress-glow" id="mil-prog-glow" style="left:0%"></div>
                    </div>
                    <div class="fin-milhao-progress-pct" id="mil-prog-pct">0%</div>
                  </div>

                  <!-- Stats -->
                  <div class="fin-milhao-stats">
                    <div class="fin-milhao-stat">
                      <span class="fin-milhao-stat-label">Meses até a meta</span>
                      <span class="fin-milhao-stat-val" id="mil-meses">--</span>
                    </div>
                    <div class="fin-milhao-stat">
                      <span class="fin-milhao-stat-label">Total aportado</span>
                      <span class="fin-milhao-stat-val" id="mil-total-aportado">--</span>
                    </div>
                    <div class="fin-milhao-stat">
                      <span class="fin-milhao-stat-label">Juros gerados</span>
                      <span class="fin-milhao-stat-val fin-val-positive" id="mil-juros">--</span>
                    </div>
                  </div>

                  <!-- Mini chart de evolução -->
                  <div class="fin-milhao-chart-wrap">
                    <canvas id="mil-chart-evolucao"></canvas>
                  </div>

                </div>
              </div>

            </div>
          </div><!-- /#fin-pane-milhao -->

        </div><!-- /.fin-layout -->
      </section>

    </main><!-- /.content -->
  </div><!-- /.layout -->

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <script src="{{ url_for('static', filename='js/main.js') }}"></script>
  <script src="{{ url_for('static', filename='js/voice.js') }}"></script>
  <script src="{{ url_for('static', filename='js/app.js') }}"></script>
  <script src="{{ url_for('static', filename='js/architect.js') }}"></script>
  <script src="{{ url_for('static', filename='js/carousel.js') }}"></script>
  <script src="{{ url_for('static', filename='js/relatorios.js') }}"></script>
  <script src="{{ url_for('static', filename='js/copys.js') }}"></script>
  <script src="{{ url_for('static', filename='js/prompts.js') }}"></script>
  <script src="{{ url_for('static', filename='js/creative_factory.js') }}"></script>
  <script src="{{ url_for('static', filename='js/financeiro.js') }}"></script>
</body>
</html>
