<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jake IA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&family=Rajdhani:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/dashboard.css') }}">
</head>
<body>

  <div class="layout">

    <!-- ── Sidebar ─────────────────────────────────────── -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        Jake <span class="brand-os">IA</span>
      </div>

      <nav class="sidebar-nav">
        <a class="nav-item active" data-page="painel" href="#">
          <span class="nav-icon">⬡</span>
          <span class="nav-label">Painel Inicial</span>
        </a>
        <a class="nav-item" data-page="architect" href="#">
          <span class="nav-icon">🧩</span>
          <span class="nav-label">Site Architect</span>
        </a>
        <a class="nav-item" data-page="performance" href="#">
          <span class="nav-icon">◈</span>
          <span class="nav-label">Análise de Performance</span>
        </a>
        <a class="nav-item" data-page="anuncios" href="#">
          <span class="nav-icon">▲</span>
          <span class="nav-label">Subir Anúncios</span>
        </a>
        <a class="nav-item" data-page="copys" href="#">
          <span class="nav-icon">✦</span>
          <span class="nav-label">Criar Copys</span>
        </a>
        <a class="nav-item" data-page="criativos" href="#">
          <span class="nav-icon">⚙️</span>
          <span class="nav-label">Fábrica de Criativos</span>
        </a>
        <a class="nav-item" data-page="relatorios" href="#">
          <span class="nav-icon">◉</span>
          <span class="nav-label">Envio de Relatórios</span>
        </a>
        <a class="nav-item" data-page="carrossel" href="#">
          <span class="nav-icon">◫</span>
          <span class="nav-label">Gerador de Carrossel</span>
        </a>
        <a class="nav-item" data-page="prompts" href="#">
          <span class="nav-icon">✴</span>
          <span class="nav-label">Gerador de Prompts</span>
        </a>
        <a class="nav-item" data-page="financeiro" href="#">
          <span class="nav-icon">₿</span>
          <span class="nav-label">Financeiro Pessoal</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <span class="user-email">{{ user_email }}</span>
        <a href="/auth/logout" class="btn-logout">↩ Sair</a>
      </div>
    </aside>

    <!-- ── Conteúdo principal ───────────────────────────── -->
    <main class="content">

      <!-- 1. PAINEL INICIAL ───────────────────────────── -->
      <section class="page active" id="page-painel">
        <div class="bg-grid-inner"></div>

        <header class="panel-header">
          <h1 class="panel-title">Jake <span class="cyan">IA</span></h1>
          <p class="panel-sub">Assistente inteligente</p>
        </header>

        <div class="painel-main">

          <!-- Cards esquerda -->
          <aside class="cards cards-left">
            <article class="card card-time">
              <div class="card-icon">🕐</div>
              <h2 class="card-title">Hora &amp; Data</h2>
              <p class="card-value card-time-value" id="time">--:--:--</p>
              <p class="card-meta" id="date">--/--/----</p>
            </article>
            <article class="card card-weather">
              <div class="card-icon">🌡️</div>
              <h2 class="card-title">Temperatura</h2>
              <p class="card-value" id="temp">-- °C</p>
              <p class="card-meta" id="humidity">Umidade: --%</p>
            </article>
          </aside>

          <!-- Esfera central -->
          <section class="hero">
            <div class="sphere-wrap" id="sphere-wrap">
              <div class="sphere-ring" id="sphere-ring" aria-hidden="true"></div>
              <div class="sphere sphere-outer"></div>
              <div class="sphere sphere-mid"></div>
              <div class="sphere sphere-core"></div>
              <div class="sphere sphere-inner"></div>
            </div>
            <div class="voice-section">
              <button type="button" class="btn-activate" id="btn-activate">
                Toque para ativar — microfone sempre ouvindo
              </button>
              <p class="voice-status" id="voice-status"></p>
              <div class="voice-response voice-response-mini" id="voice-response" aria-live="polite"></div>
            </div>
          </section>

          <!-- Cards direita -->
          <aside class="cards cards-right">
            <article class="card card-greeting">
              <div class="card-icon card-greeting-emoji" id="greeting-emoji">🌙</div>
              <h2 class="card-title">Olá</h2>
              <p class="card-value card-greeting-text" id="greeting">Boa noite, patrão</p>
              <p class="card-meta">Pronto para ajudar</p>
            </article>
            <article class="card card-status">
              <div class="status-check-wrap">
                <span class="status-check" aria-hidden="true">✓</span>
              </div>
              <h2 class="card-title">Status</h2>
              <p class="card-value card-status-value">Online</p>
              <p class="card-meta">Sistema pronto</p>
            </article>
          </aside>

        </div><!-- /.painel-main -->
      </section>

      <!-- 1.1 SITE ARCHITECT ───────────────────────────── -->
      <section class="page" id="page-architect">
        <div class="sa-layout">

          <!-- Lado Esquerdo: Configurações -->
          <aside class="sa-sidebar">
            <header class="sa-header">
              <span class="sa-header-icon">🧩</span>
              <div>
                <h2 class="sa-title">Site <span class="cyan">Architect</span></h2>
                <p class="sa-subtitle">Gere uma landing page completa a partir de uma referência, contexto e assets.</p>
              </div>
            </header>

            <div class="sa-form">
              <div class="sa-group-label">Referência</div>

              <div class="sa-field">
                <label class="sa-label" for="sa-ref-url">URL de referência</label>
                <input id="sa-ref-url" class="sa-input" type="url" placeholder="Ex.: https://site-de-referencia.com">
                <p class="sa-hint">O Jake não copia o código. Ele lê a estrutura (seções, fluxo) para espelhar o layout.</p>
              </div>

              <div class="sa-field">
                <label class="sa-label" for="sa-contexto">Contexto do seu negócio</label>
                <textarea id="sa-contexto" class="sa-textarea" rows="3" placeholder="Ex.: Agência de tráfego paga focada em dentistas de alto ticket, atendimento em todo Brasil, foco em captação via Meta Ads."></textarea>
              </div>

              <div class="sa-group-label">Copy & Posicionamento</div>

              <div class="sa-field">
                <label class="sa-label" for="sa-template">Template de landing</label>
                <div class="cp-select-wrap">
                  <select id="sa-template" class="cp-select">
                    <option value="lead">Captura de leads (isca/consulta)</option>
                    <option value="lancamento">Lançamento / lançamento perpétuo</option>
                    <option value="servico-local">Serviço local (clínica, escritório, salão)</option>
                    <option value="saas">Software / SaaS</option>
                    <option value="ecommerce">E‑commerce simples (1 produto principal)</option>
                  </select>
                  <span class="cp-select-arrow">▾</span>
                </div>
              </div>

              <div class="sa-field">
                <label class="sa-label" for="sa-copy-hero">Copy principal (Hero)</label>
                <textarea id="sa-copy-hero" class="sa-textarea" rows="2" placeholder="Headline + subheadline da seção de abertura."></textarea>
              </div>

              <div class="sa-field">
                <label class="sa-label" for="sa-copy-extra">Outras infos importantes</label>
                <textarea id="sa-copy-extra" class="sa-textarea" rows="3" placeholder="Benefícios, provas sociais, ofertas, garantias, objeções que quer quebrar, etc."></textarea>
              </div>

              <div class="sa-group-label">Assets visuais</div>

              <div class="sa-upload-grid">
                <div class="sa-upload-card">
                  <label class="sa-label">Logotipo</label>
                  <div class="sa-dropzone" data-kind="logo">
                    <input type="file" accept="image/*" class="sa-file-input">
                    <div class="sa-drop-placeholder">
                      <span>⬆</span>
                      <p>Upload ou arraste aqui</p>
                    </div>
                    <img class="sa-preview hidden" alt="">
                  </div>
                </div>
                <div class="sa-upload-card">
                  <label class="sa-label">Banner principal</label>
                  <div class="sa-dropzone" data-kind="hero">
                    <input type="file" accept="image/*" class="sa-file-input">
                    <div class="sa-drop-placeholder">
                      <span>⬆</span>
                      <p>Upload ou arraste aqui</p>
                    </div>
                    <img class="sa-preview hidden" alt="">
                  </div>
                </div>
                <div class="sa-upload-card">
                  <label class="sa-label">Fotos de produto / serviço</label>
                  <div class="sa-dropzone" data-kind="gallery">
                    <input type="file" accept="image/*" multiple class="sa-file-input">
                    <div class="sa-drop-placeholder">
                      <span>⬆</span>
                      <p>Até 6 imagens</p>
                    </div>
                    <div class="sa-preview-grid"></div>
                  </div>
                </div>
                <div class="sa-upload-card">
                  <label class="sa-label">Imagens da seção de Benefícios</label>
                  <div class="sa-dropzone" data-kind="benefits">
                    <input type="file" accept="image/*" multiple class="sa-file-input">
                    <div class="sa-drop-placeholder">
                      <span>⬆</span>
                      <p>Ícones/fotos para Benefícios</p>
                    </div>
                    <div class="sa-preview-grid"></div>
                  </div>
                </div>
                <div class="sa-upload-card">
                  <label class="sa-label">Imagens da seção de Prova Social / Resultados</label>
                  <div class="sa-dropzone" data-kind="social">
                    <input type="file" accept="image/*" multiple class="sa-file-input">
                    <div class="sa-drop-placeholder">
                      <span>⬆</span>
                      <p>Prints de resultado, depoimentos, etc.</p>
                    </div>
                    <div class="sa-preview-grid"></div>
                  </div>
                </div>
              </div>

              <div class="sa-actions">
                <button id="sa-generate-btn" class="sa-btn-primary">
                  <span class="sa-btn-icon">✦</span>
                  <span>Gerar estrutura de site</span>
                </button>
                <button id="sa-reset-btn" class="sa-btn-ghost">Limpar tudo</button>
              </div>

              <div id="sa-status" class="sa-status"></div>
            </div>
          </aside>

          <!-- Lado Direito: Preview + Chat -->
          <div class="sa-main">
            <div class="sa-toolbar">
              <span class="sa-toolbar-label">Preview ao vivo</span>
              <div class="sa-toolbar-right">
                <button id="sa-view-code-btn" class="sa-chip-toggle" data-mode="preview">Preview</button>
                <button id="sa-view-html-btn" class="sa-chip-toggle" data-mode="html">HTML</button>
                <button id="sa-export-btn" class="sa-chip-toggle" data-mode="export">Baixar index.html</button>
                <button id="sa-export-react-btn" class="sa-chip-toggle" data-mode="export-react">Baixar React</button>
                <button id="sa-publish-btn" class="sa-btn-publish">Publicar na Vercel</button>
              </div>
            </div>

            <div class="sa-preview-area">
              <iframe id="sa-iframe" title="Preview do site" class="sa-iframe"></iframe>
              <pre id="sa-html-view" class="sa-html-view hidden"></pre>
            </div>

            <div class="sa-chat">
              <div class="sa-chat-header">
                <span class="sa-chat-title">Refinar por chat</span>
                <span class="sa-chat-hint">Ex.: "mude a cor dos botões para verde" · "adicione seção de depoimentos"</span>
              </div>
              <div class="sa-chat-body" id="sa-chat-log"></div>
              <form id="sa-chat-form" class="sa-chat-form">
                <input id="sa-chat-input" class="sa-chat-input" type="text" autocomplete="off" placeholder="Descreva o ajuste que quer fazer no layout ou na copy…">
                <button class="sa-chat-send" type="submit">Enviar</button>
              </form>
            </div>
          </div>

        </div>
      </section>

      <!-- 2. ANÁLISE DE PERFORMANCE ───────────────────── -->
      <section class="page" id="page-performance">
        <div class="placeholder-page">
          <div class="placeholder-icon">◈</div>
          <h2 class="placeholder-title">Análise de Performance</h2>
          <p class="placeholder-sub">Em desenvolvimento — em breve aqui você terá gasto, CPL, ROAS e CPA por cliente.</p>
          <div class="placeholder-grid">
            <div class="ph-card"><span>Gasto Total</span><b>-- R$</b></div>
            <div class="ph-card"><span>CPL</span><b>-- R$</b></div>
            <div class="ph-card"><span>ROAS</span><b>--x</b></div>
            <div class="ph-card"><span>CPA</span><b>-- R$</b></div>
          </div>
        </div>
      </section>

      <!-- 3. SUBIR ANÚNCIOS ───────────────────────────── -->
      <section class="page" id="page-anuncios">
        <div class="placeholder-page">
          <div class="placeholder-icon">▲</div>
          <h2 class="placeholder-title">Subir Anúncios</h2>
          <p class="placeholder-sub">Em desenvolvimento — selecione o cliente, faça upload dos criativos, cole a copy e dispare para a Meta.</p>
          <div class="placeholder-steps">
            <div class="ph-step">① Selecionar cliente</div>
            <div class="ph-step">② Upload de criativos</div>
            <div class="ph-step">③ Colar copy</div>
            <div class="ph-step ph-step-cta">🚀 Disparar para a Meta</div>
          </div>
        </div>
      </section>

      <!-- 4. CRIAR COPYS ──────────────────────────────── -->
      <section class="page" id="page-copys">
        <div class="cp-layout">

          <!-- ── Painel Esquerdo: Configurações ─────── -->
          <aside class="cp-sidebar">

            <header class="cp-header">
              <span class="cp-header-icon">✦</span>
              <div>
                <h2 class="cp-title">Máquina de <span class="cyan">Copys</span></h2>
                <p class="cp-subtitle">Gerador de textos persuasivos para anúncios de alta conversão</p>
              </div>
            </header>

            <div class="cp-form">

              <!-- ── Grupo: Destino ── -->
              <div class="cp-group-label">Destino &amp; Estrutura</div>

              <div class="cp-field">
                <label class="cp-label" for="cp-plataforma">Plataforma</label>
                <div class="cp-select-wrap">
                  <select id="cp-plataforma" class="cp-select">
                    <option value="Meta Ads (Facebook/Instagram)">Meta Ads (Facebook / Instagram)</option>
                    <option value="Google Ads (Rede de Pesquisa)">Google Ads (Rede de Pesquisa)</option>
                    <option value="TikTok Ads">TikTok Ads</option>
                    <option value="YouTube In-Stream">YouTube In-Stream</option>
                  </select>
                  <span class="cp-select-arrow">▾</span>
                </div>
              </div>

              <div class="cp-field">
                <label class="cp-label" for="cp-framework">Framework / Estrutura</label>
                <div class="cp-select-wrap">
                  <select id="cp-framework" class="cp-select">
                    <option value="AIDA (Atenção, Interesse, Desejo, Ação)">AIDA — Atenção, Interesse, Desejo, Ação</option>
                    <option value="PAS (Problema, Agitação, Solução)">PAS — Problema, Agitação, Solução</option>
                    <option value="Storytelling Rápido">Storytelling Rápido</option>
                    <option value="Oferta Direta / Varejo">Oferta Direta / Varejo</option>
                    <option value="Quebra de Objeção (Remarketing)">Quebra de Objeção — Remarketing</option>
                    <option value="Roteiro de Vídeo (Reels/TikTok)">Roteiro de Vídeo (Reels / TikTok)</option>
                  </select>
                  <span class="cp-select-arrow">▾</span>
                </div>
              </div>

              <!-- ── Grupo: Funil e Gatilho ── -->
              <div class="cp-group-label">Funil &amp; Gatilho</div>

              <div class="cp-grid2">
                <div class="cp-field">
                  <label class="cp-label" for="cp-consciencia">Nível de Consciência</label>
                  <div class="cp-select-wrap">
                    <select id="cp-consciencia" class="cp-select">
                      <option value="Público Frio (Topo de Funil — Apresentação)">❄ Frio — Topo</option>
                      <option value="Público Morno (Meio de Funil — Consideração)">🌡 Morno — Meio</option>
                      <option value="Público Quente (Fundo de Funil — Decisão de Compra)">🔥 Quente — Fundo</option>
                    </select>
                    <span class="cp-select-arrow">▾</span>
                  </div>
                </div>
                <div class="cp-field">
                  <label class="cp-label" for="cp-gatilho">Gatilho Mental</label>
                  <div class="cp-select-wrap">
                    <select id="cp-gatilho" class="cp-select">
                      <option value="Urgência">⏰ Urgência</option>
                      <option value="Escassez">🔒 Escassez</option>
                      <option value="Prova Social">⭐ Prova Social</option>
                      <option value="Autoridade">🏆 Autoridade</option>
                      <option value="Curiosidade">🎯 Curiosidade</option>
                    </select>
                    <span class="cp-select-arrow">▾</span>
                  </div>
                </div>
              </div>

              <!-- ── Grupo: Calibração ── -->
              <div class="cp-group-label">Calibração</div>

              <div class="cp-grid2">
                <div class="cp-field">
                  <label class="cp-label" for="cp-tom">Tom de Voz</label>
                  <div class="cp-select-wrap">
                    <select id="cp-tom" class="cp-select">
                      <option value="Agressivo e Urgente (gatilhos fortes, escassez)">Agressivo</option>
                      <option value="Autoridade e Especialista (dados, segurança, confiança)">Autoridade</option>
                      <option value="Empático e Acolhedor (saúde, clínicas, estética)">Empático</option>
                      <option value="Curto, Seco e Direto ao Ponto">Direto</option>
                      <option value="Descontraído e Irônico (público jovem)">Descontraído</option>
                    </select>
                    <span class="cp-select-arrow">▾</span>
                  </div>
                </div>
                <div class="cp-field">
                  <label class="cp-label" for="cp-tamanho">Tamanho</label>
                  <div class="cp-select-wrap">
                    <select id="cp-tamanho" class="cp-select">
                      <option value="Curta (Stories/Reels — máx 3 frases)">Curta — Stories</option>
                      <option value="Média (Feed — 3 a 4 parágrafos)" selected>Média — Feed</option>
                      <option value="Longa (Texto Persuasivo — 600 a 1200 chars)">Longa — VSL</option>
                    </select>
                    <span class="cp-select-arrow">▾</span>
                  </div>
                </div>
              </div>

              <!-- ── Grupo: Contexto ── -->
              <div class="cp-group-label">Contexto do Anúncio</div>

              <div class="cp-grid2">
                <div class="cp-field">
                  <label class="cp-label" for="cp-profissao">Profissão / Especialista</label>
                  <input type="text" id="cp-profissao" class="cp-input"
                    placeholder="Ex: Médico, Mentor...">
                </div>
                <div class="cp-field">
                  <label class="cp-label" for="cp-nicho">Nicho / Público-Alvo</label>
                  <input type="text" id="cp-nicho" class="cp-input"
                    placeholder="Ex: Mulheres 30+...">
                </div>
              </div>

              <div class="cp-field">
                <label class="cp-label" for="cp-oferta">A Oferta / Produto <span class="cp-required">*</span></label>
                <textarea id="cp-oferta" class="cp-textarea" rows="4"
                  placeholder="Ex: Clareamento dental a laser com 30% OFF só até sexta-feira. Atendimento no centro de SP, vagas limitadas."></textarea>
              </div>

              <div class="cp-field">
                <label class="cp-label" for="cp-cta">CTA — Chamada para Ação</label>
                <input type="text" id="cp-cta" class="cp-input"
                  placeholder='Ex: "Clique em Saiba Mais", "Mande um Direct"'>
              </div>

              <!-- Toggle Emojis -->
              <div class="cp-toggle-wrap">
                <span class="cp-toggle-label-text">Usar Emojis</span>
                <label class="cp-toggle">
                  <input type="checkbox" id="cp-emojis">
                  <span class="cp-toggle-slider"></span>
                </label>
              </div>

              <!-- Botões de ação -->
              <div class="cp-btn-row">
                <button id="cp-gerar-btn" class="cp-btn-primary">
                  <span class="cp-btn-icon">✦</span>
                  <span class="cp-btn-text">Gerar Copy</span>
                </button>
                <button id="cp-variacao-btn" class="cp-btn-variation" title="Gerar uma variação com ângulo diferente para teste A/B">
                  <span class="cp-var-text">🔄 Variação A/B</span>
                </button>
              </div>

            </div>
          </aside>

          <!-- ── Painel Direito: Resultado ───────────── -->
          <div class="cp-result-panel">

            <div class="cp-result-topbar">
              <span class="cp-result-label">Copy Gerada</span>
              <div class="cp-badges" id="cp-badges"></div>
            </div>

            <div class="cp-output-area" id="cp-output-area">

              <!-- Estado vazio inicial -->
              <div class="cp-empty" id="cp-empty">
                <div class="cp-empty-icon">✦</div>
                <p class="cp-empty-text">Configure os parâmetros ao lado e clique em<br><strong>Gerar Copy</strong> para começar.</p>
              </div>

              <!-- Animação de carregamento -->
              <div class="cp-loading hidden" id="cp-loading">
                <div class="cp-loading-dots">
                  <span></span><span></span><span></span>
                </div>
                <p class="cp-loading-text">Gerando copy de alta conversão...</p>
              </div>

              <!-- Texto gerado (plain — sem seções) -->
              <pre class="cp-output hidden" id="cp-output"></pre>

              <!-- Texto gerado em seções (Meta, Google, YouTube, TikTok) -->
              <div class="cp-sections hidden" id="cp-sections"></div>

            </div>

            <!-- Rodapé com botão copiar tudo -->
            <div class="cp-result-footer hidden" id="cp-footer">
              <button class="cp-copy-btn" id="cp-copy-btn">
                <svg id="cp-copy-icon-svg" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <svg id="cp-check-icon-svg" class="hidden" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span id="cp-copy-label">Copiar Tudo</span>
              </button>
            </div>

          </div><!-- /.cp-result-panel -->

        </div><!-- /.cp-layout -->
      </section>

      <!-- 4.1 FÁBRICA DE CRIATIVOS ────────────────────── -->
      <section class="page" id="page-criativos">
        <div class="cp-layout">

          <!-- ── Sidebar Esquerda: Configurações ───────── -->
          <aside class="cp-sidebar">

            <header class="cp-header">
              <span class="cp-header-icon">⚙️</span>
              <div>
