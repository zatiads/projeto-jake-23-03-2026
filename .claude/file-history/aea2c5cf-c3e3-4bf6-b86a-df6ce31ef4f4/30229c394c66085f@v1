  box-shadow: 0 0 0 2px rgba(0,229,255,.12);
}

.pg-select option { background: #0d1520; color: var(--white); }

.pg-select-arrow {
  position: absolute;
  right: .75rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--cyan);
  pointer-events: none;
  font-size: .75rem;
}

.pg-textarea {
  width: 100%;
  padding: .6rem .85rem;
  background: rgba(0,229,255,.04);
  border: 1px solid rgba(0,229,255,.18);
  border-radius: 8px;
  color: var(--white);
  font-family: var(--ff-b);
  font-size: .9rem;
  resize: vertical;
  line-height: 1.5;
  transition: border-color .2s, box-shadow .2s;
}

.pg-textarea:focus {
  outline: none;
  border-color: var(--cyan-dim);
  box-shadow: 0 0 0 2px rgba(0,229,255,.12);
}

.pg-textarea::placeholder { color: rgba(176,190,197,.35); }

.pg-input {
  width: 100%;
  padding: .55rem .85rem;
  background: rgba(0,229,255,.04);
  border: 1px solid rgba(0,229,255,.18);
  border-radius: 8px;
  color: var(--white);
  font-family: var(--ff-b);
  font-size: .9rem;
  transition: border-color .2s, box-shadow .2s;
}

.pg-input:focus {
  outline: none;
  border-color: var(--cyan-dim);
  box-shadow: 0 0 0 2px rgba(0,229,255,.12);
}

.pg-input::placeholder { color: rgba(176,190,197,.35); }

.pg-btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .6rem;
  width: 100%;
  padding: .8rem 1.2rem;
  margin-top: .5rem;
  background: linear-gradient(135deg, #00b8d4, #0097a7);
  border: none;
  border-radius: 10px;
  color: #000;
  font-family: var(--ff-h);
  font-size: .82rem;
  font-weight: 700;
  letter-spacing: .06em;
  cursor: pointer;
  transition: opacity .2s, box-shadow .2s, transform .15s;
  box-shadow: 0 0 20px rgba(0,229,255,.25);
}

.pg-btn-primary:hover:not(:disabled) {
  opacity: .92;
  box-shadow: 0 0 30px rgba(0,229,255,.45);
  transform: translateY(-1px);
}

.pg-btn-primary:disabled { opacity: .45; cursor: not-allowed; transform: none; }

.pg-btn-icon { font-size: 1rem; }

/* ── Painel direito ── */
.pg-result-panel {
  display: flex;
  flex-direction: column;
  background: rgba(7,11,18,.6);
  overflow: hidden;
}

.pg-result-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 1.4rem;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.pg-result-label {
  font-family: var(--ff-h);
  font-size: .75rem;
  font-weight: 600;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: rgba(176,190,197,.5);
}

.pg-result-badge {
  font-family: var(--ff-h);
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .15em;
  padding: .2rem .55rem;
  border-radius: 4px;
  background: rgba(0,229,255,.12);
  border: 1px solid rgba(0,229,255,.3);
  color: var(--cyan);
}

.pg-output-area {
  flex: 1;
  overflow-y: auto;
  padding: 1.4rem;
  scrollbar-width: thin;
  scrollbar-color: var(--cyan-dim) transparent;
  display: flex;
  flex-direction: column;
}

/* Estado vazio */
.pg-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  opacity: .45;
}

.pg-empty-icon {
  font-size: 2.5rem;
  color: var(--cyan);
  filter: drop-shadow(0 0 10px var(--cyan-glow));
  animation: pg-pulse 3s ease-in-out infinite;
}

@keyframes pg-pulse {
  0%, 100% { opacity: .4; transform: scale(1); }
  50%       { opacity: .8; transform: scale(1.08); }
}

.pg-empty-text {
  font-size: .9rem;
  text-align: center;
  line-height: 1.6;
  color: rgba(176,190,197,.5);
}

.pg-empty-text strong { color: var(--cyan); font-weight: 600; }

/* Loading */
.pg-loading {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1.2rem;
}

.pg-loading-dots {
  display: flex;
  gap: .4rem;
}

.pg-loading-dots span {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--cyan);
  animation: pg-dot-bounce .9s ease-in-out infinite;
}

.pg-loading-dots span:nth-child(2) { animation-delay: .15s; }
.pg-loading-dots span:nth-child(3) { animation-delay: .3s; }

@keyframes pg-dot-bounce {
  0%, 80%, 100% { transform: scale(.8); opacity: .4; }
  40%            { transform: scale(1.2); opacity: 1; }
}

.pg-loading-text {
  font-size: .85rem;
  color: rgba(176,190,197,.55);
  letter-spacing: .04em;
}

/* Output */
.pg-output {
  flex: 1;
  font-family: var(--ff-b);
  font-size: .95rem;
  line-height: 1.75;
  color: #e8f5e9;
  white-space: pre-wrap;
  word-break: break-word;
  background: rgba(0,229,255,.025);
  border: 1px solid rgba(0,229,255,.1);
  border-radius: 10px;
  padding: 1.2rem 1.4rem;
  letter-spacing: .015em;
}

/* Rodapé / botão copiar */
.pg-result-footer {
  padding: .85rem 1.4rem;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}

.pg-copy-btn {
  display: flex;
  align-items: center;
  gap: .5rem;
  padding: .55rem 1rem;
  background: rgba(0,229,255,.07);
  border: 1px solid rgba(0,229,255,.22);
  border-radius: 8px;
  color: var(--cyan);
  font-family: var(--ff-b);
  font-size: .85rem;
  cursor: pointer;
  transition: background .2s, box-shadow .2s;
}

.pg-copy-btn:hover { background: rgba(0,229,255,.14); box-shadow: 0 0 12px rgba(0,229,255,.2); }
.pg-copy-btn.copied { background: rgba(105,240,174,.1); border-color: rgba(105,240,174,.35); color: var(--green); }

/* Utilitário */
.hidden { display: none !important; }

/* Responsive */
@media (max-width: 900px) {
  .pg-layout { grid-template-columns: 1fr; height: auto; overflow: auto; }
  .pg-sidebar { border-right: none; border-bottom: 1px solid var(--border); }
  .pg-result-panel { min-height: 60vh; }
}

/* ══════════════════════════════════════════════════════
   FINANCEIRO PESSOAL — Layout base
══════════════════════════════════════════════════════ */

#page-financeiro {
  overflow-y: auto;
}

.fin-layout {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  padding: 1.6rem 2.4rem 2.1rem;
  max-width: 1200px;
  margin: 0 auto;
}

.fin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border);
}

.fin-header-left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.fin-header-icon {
  font-size: 2rem;
  filter: drop-shadow(0 0 14px var(--cyan-glow));
}

.fin-title {
  font-family: var(--ff-h);
  font-size: 1.4rem;
  font-weight: 800;
  letter-spacing: .14em;
  color: var(--white);
  text-transform: uppercase;
}

.fin-sub {
  font-size: .85rem;
  color: rgba(176,190,197,.55);
  margin-top: .2rem;
}

/* Tabs internas */
.fin-tabs-nav {
  display: flex;
  gap: .5rem;
  margin-top: 1.1rem;
  border-bottom: 1px solid var(--border);
  padding-bottom: .55rem;
}

.fin-visao-toolbar {
  display: flex;
  justify-content: flex-end;
  margin-top: 1.1rem;
  margin-bottom: .5rem;
}

.fin-mes-filter {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: .3rem;
}

.fin-mes-filter-label {
  font-size: .72rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: rgba(176,190,197,.6);
}

.fin-mes-filter-controls {
  min-width: 150px;
}

.fin-tab-btn {
  display: flex;
  align-items: center;
  gap: .45rem;
  padding: .45rem 1.15rem;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text);
  font-family: var(--ff-b);
  font-size: .9rem;
  letter-spacing: .05em;
  cursor: pointer;
  transition: all .18s;
}

.fin-tab-btn span:first-child {
  font-size: .9rem;
}

.fin-tab-btn:hover {
  background: rgba(0,229,255,.06);
  color: var(--white);
  border-color: rgba(0,229,255,.3);
}

.fin-tab-btn.active {
  background: rgba(0,229,255,.14);
  color: var(--cyan);
  border-color: var(--cyan);
  box-shadow: 0 0 14px rgba(0,229,255,.25);
}

/* Conteúdo das abas */
.fin-tab-pane {
  display: none;
  margin-top: 1.4rem;
  flex-direction: column;
  gap: 1.4rem;
}

.fin-tab-pane.active {
  display: flex;
}

/* KPI cards */
.fin-kpi-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0,1fr));
  gap: 1rem;
}

.fin-kpi-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.1rem 1.3rem;
  backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  gap: .25rem;
  position: relative;
  overflow: hidden;
  transition: border-color .2s, box-shadow .2s, transform .15s;
}

.fin-kpi-card::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0;
  background: radial-gradient(circle at top, rgba(0,229,255,.18), transparent 55%);
  pointer-events: none;
  transition: opacity .25s;
}

.fin-kpi-card:hover {
  border-color: rgba(0,229,255,.38);
  box-shadow: 0 6px 24px rgba(0,229,255,.22);
  transform: translateY(-2px);
}

.fin-kpi-card:hover::before {
  opacity: 1;
}

.fin-kpi-icon {
  font-size: 1.15rem;
  opacity: .8;
}

.fin-kpi-label {
  font-size: .75rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: rgba(176,190,197,.6);
}

.fin-kpi-value {
  font-family: var(--ff-h);
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: .06em;
}

.fin-kpi-sub {
  font-size: .78rem;
  color: rgba(176,190,197,.5);
}

.fin-val-positive {
  color: var(--green);
  text-shadow: 0 0 10px var(--green-glow);
}

.fin-val-negative {
  color: var(--red);
  text-shadow: 0 0 10px rgba(255,82,82,.45);
}

/* Gráficos visão geral */
.fin-charts-row {
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 1rem;
}

.fin-chart-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.1rem 1.3rem 1rem;
  backdrop-filter: blur(10px);
}

.fin-chart-title {
  font-family: var(--ff-b);
  font-size: .95rem;
  font-weight: 600;
  color: var(--white);
  letter-spacing: .04em;
  margin-bottom: .75rem;
}

.fin-chart-wrap {
  position: relative;
  height: 220px;
}

/* Análise de IA */
.fin-ai-section {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.fin-ai-btn {
  display: inline-flex;
  align-items: center;
  gap: .6rem;
  padding: .7rem 1.8rem;
  background: rgba(0,229,255,.08);
  border: 1px solid var(--cyan);
  border-radius: 10px;
  color: var(--cyan);
  font-family: var(--ff-h);
  font-size: .9rem;
  font-weight: 600;
  letter-spacing: .08em;
  cursor: pointer;
  transition: all .25s;
  box-shadow: 0 0 16px rgba(0,229,255,.15), inset 0 0 20px rgba(0,229,255,.04);
  align-self: flex-start;
}

.fin-ai-btn:hover {
  background: rgba(0,229,255,.18);
  box-shadow: 0 0 28px rgba(0,229,255,.3), inset 0 0 24px rgba(0,229,255,.08);
  transform: translateY(-1px);
}

.fin-ai-btn-icon {
  font-size: 1rem;
}

.fin-ai-result {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.1rem 1.4rem;
  backdrop-filter: blur(10px);
}

.fin-ai-loading {
  display: flex;
  align-items: center;
  gap: .8rem;
  font-size: .9rem;
  color: var(--text);
}

.fin-ai-dots {
  display: flex;
  gap: .25rem;
}

.fin-ai-dots span {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--cyan);
  animation: finDotBounce 1.1s ease-in-out infinite;
}

.fin-ai-dots span:nth-child(2) { animation-delay: .18s; }
.fin-ai-dots span:nth-child(3) { animation-delay: .36s; }

@keyframes finDotBounce {
  0%, 80%, 100% { transform: scale(.7); opacity: .4; }
  40%          { transform: scale(1.1); opacity: 1;  }
}

.fin-ai-text {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--white);
}

.fin-ai-jake {
  font-family: var(--ff-h);
  font-size: .78rem;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: var(--cyan);
  display: inline-block;
  margin-bottom: .4rem;
}

/* Lançamentos */
.fin-form-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.2rem 1.4rem;
  backdrop-filter: blur(10px);
}

.fin-form-title {
  font-family: var(--ff-b);
  font-size: 1rem;
  font-weight: 600;
  color: var(--white);
  letter-spacing: .04em;
  margin-bottom: 1rem;
}

.fin-form-grid {
  display: grid;
  grid-template-columns: 2.1fr 1fr 1fr 1fr 1fr auto;
  gap: .75rem;
  align-items: flex-end;
}

.fin-form-field {
  display: flex;
  flex-direction: column;
  gap: .35rem;
}

.fin-label {
  font-size: .78rem;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: rgba(176,190,197,.55);
}

.fin-input {
  background: rgba(0,229,255,.04);
  border: 1px solid rgba(0,229,255,.18);
  border-radius: 8px;
  padding: .55rem .8rem;
  color: var(--white);
  font-family: var(--ff-b);
  font-size: .95rem;
  transition: border-color .2s, box-shadow .2s;
}

.fin-input:focus {
  outline: none;
  border-color: var(--cyan);
  box-shadow: 0 0 0 3px rgba(0,229,255,.12);
}

.fin-select-wrap {
  position: relative;
}

.fin-select {
  appearance: none;
  width: 100%;
  background: rgba(0,229,255,.04);
  border: 1px solid rgba(0,229,255,.18);
  border-radius: 8px;
  padding: .55rem 2rem .55rem .8rem;
  color: var(--white);
  font-family: var(--ff-b);
  font-size: .95rem;
  cursor: pointer;
}

.fin-select:focus {
  outline: none;
  border-color: var(--cyan);
}

.fin-select-arrow {
  position: absolute;
  right: .8rem;
  top: 50%;
  transform: translateY(-50%);
  font-size: .8rem;
  color: rgba(0,229,255,.7);
  pointer-events: none;
}

.fin-field-check {
  justify-content: flex-end;
}

.fin-toggle-wrap {
  display: flex;
  align-items: center;
  gap: .5rem;
  padding: .5rem .3rem;
}

.fin-toggle-input {
  display: none;
}

.fin-toggle-slider {
  width: 36px;
  height: 20px;
  background: rgba(176,190,197,.25);
  border-radius: 10px;
  position: relative;
  transition: background .18s;
}

.fin-toggle-slider::after {
  content: '';
  position: absolute;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--text);
  top: 3px;
  left: 3px;
  transition: transform .18s, background .18s, box-shadow .18s;
}

.fin-toggle-input:checked + .fin-toggle-slider {
  background: rgba(0,229,255,.3);
}

.fin-toggle-input:checked + .fin-toggle-slider::after {
  transform: translateX(16px);
  background: var(--cyan);
  box-shadow: 0 0 6px var(--cyan-glow);
}

.fin-toggle-text {
  font-size: .9rem;
  color: var(--text);
}

.fin-form-footer {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}

.fin-add-btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .6rem 1.5rem;
  background: rgba(0,229,255,.12);
  border: 1px solid var(--cyan);
  border-radius: 9px;
  color: var(--cyan);
  font-family: var(--ff-b);
  font-size: .95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .2s;
  box-shadow: 0 0 14px rgba(0,229,255,.18);
}

.fin-add-btn:hover {
  background: rgba(0,229,255,.2);
  box-shadow: 0 0 22px rgba(0,229,255,.3);
}

.fin-flash {
  padding: .45rem 1rem;
  border-radius: 7px;
  font-size: .85rem;
  font-family: var(--ff-b);
}

.fin-flash-success {
  background: rgba(105,240,174,.14);
  border: 1px solid rgba(105,240,174,.25);
  color: var(--green);
}

.fin-flash-error {
  background: rgba(255,82,82,.12);
  border: 1px solid rgba(255,82,82,.3);
  color: var(--red);
}

/* Tabela de transações */
.fin-table-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.1rem 1.3rem;
  backdrop-filter: blur(10px);
}

.fin-table-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}

.fin-table-title {
  font-family: var(--ff-b);
  font-size: 1rem;
  font-weight: 600;
  color: var(--white);
  letter-spacing: .04em;
}

.fin-mes-nav {
  display: flex;
  align-items: center;
  gap: .5rem;
}

.fin-mes-btn {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: rgba(0,229,255,.05);
  color: var(--cyan);
  cursor: pointer;
  transition: all .15s;
}

.fin-mes-btn:hover {
  border-color: var(--cyan);
  background: rgba(0,229,255,.12);
}

.fin-mes-label {
  font-family: var(--ff-b);
  font-size: .9rem;
  font-weight: 600;
  color: var(--white);
  min-width: 140px;
  text-align: center;
  letter-spacing: .03em;
}

.fin-table-scroll {
  overflow-x: auto;
}

.fin-table {
  width: 100%;
  border-collapse: collapse;
}

.fin-table th {
  font-family: var(--ff-h);
  font-size: .7rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(176,190,197,.55);
  padding: .5rem .8rem;
  text-align: left;
  border-bottom: 1px solid var(--border);
}

.fin-table td {
  padding: .6rem .8rem;
  border-bottom: 1px solid rgba(0,229,255,.06);
  font-size: .9rem;
}

.fin-table tr:hover td {
  background: rgba(0,229,255,.03);
}

.fin-empty-row {
  text-align: center;
  padding: 1.6rem !important;
  color: rgba(176,190,197,.35);
  font-style: italic;
}

.fin-td-data {
  color: rgba(176,190,197,.6);
  font-size: .85rem;
  white-space: nowrap;
}

.fin-td-desc {
  color: var(--white);
}

.fin-td-valor {
  font-family: var(--ff-h);
  font-size: .95rem;
  white-space: nowrap;
  text-align: right;
}

.fin-badge {
  display: inline-flex;
  align-items: center;
  padding: .1rem .45rem;
  border-radius: 4px;
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .05em;
  margin-left: .25rem;
}

.fin-badge-rec {
  background: rgba(0,229,255,.12);
  border: 1px solid rgba(0,229,255,.28);
  color: var(--cyan);
}

.fin-badge-fix {
  background: rgba(105,240,174,.1);
  border: 1px solid rgba(105,240,174,.25);
  color: var(--green);
}

.fin-badge-var {
  background: rgba(255,215,64,.1);
  border: 1px solid rgba(255,215,64,.25);
  color: #ffd740;
}

.fin-tipo-badge {
  display: inline-block;
  padding: .18rem .6rem;
  border-radius: 4px;
  font-size: .78rem;
  font-weight: 700;
  letter-spacing: .04em;
}

.fin-tipo-entrada {
  background: rgba(105,240,174,.12);
  color: var(--green);
  border: 1px solid rgba(105,240,174,.25);
}

.fin-tipo-saida {
  background: rgba(255,82,82,.12);
  color: var(--red);
  border: 1px solid rgba(255,82,82,.25);
}

.fin-del-btn {
  width: 26px;
  height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  border: 1px solid rgba(255,82,82,.25);
  background: transparent;
  color: rgba(255,82,82,.6);
  cursor: pointer;
  font-size: .8rem;
  transition: all .15s;
}

.fin-del-btn:hover {
  background: rgba(255,82,82,.18);
  color: var(--red);
  border-color: rgba(255,82,82,.6);
}

/* Projeções básicos (cards já tinham estilos 2.0 complementares) */
.fin-proj-header {
  text-align: left;
}

.fin-proj-title {
  font-family: var(--ff-h);
  font-size: .95rem;
  font-weight: 700;
  color: var(--white);
  letter-spacing: .08em;
  text-transform: uppercase;
}

.fin-proj-sub {
  font-size: .86rem;
  color: rgba(176,190,197,.5);
  margin-top: .35rem;
}

.fin-proj-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0,1fr));
  gap: 1.1rem;
}

.fin-proj-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.1rem 1.3rem;
  backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  gap: .6rem;
}

.fin-proj-mes {
  font-family: var(--ff-h);
  font-size: .9rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--cyan);
}

.fin-proj-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: .9rem;
  color: var(--text);
}

.fin-proj-divider {
  height: 1px;
  background: var(--border);
}

.fin-proj-saldo span:last-child {
  font-family: var(--ff-h);
}

.fin-proj-positive {
  color: var(--green);
}

.fin-proj-negative {
  color: var(--red);
}

/* ══════════════════════════════════════════════════════
   FINANCEIRO 2.0 — Raio-X + Projeto 1 Milhão + Linha
══════════════════════════════════════════════════════ */

/* ── Aba Projeto 1 Milhão ──────────────────────────── */
.fin-tab-milhao {
  background: linear-gradient(135deg, rgba(0,229,255,.06), rgba(124,77,255,.06)) !important;
  border-color: rgba(124,77,255,.3) !important;
  color: #b388ff !important;
}
.fin-tab-milhao:hover { border-color: #7c4dff !important; color: #e040fb !important; }
.fin-tab-milhao.active {
  background: linear-gradient(135deg, rgba(0,229,255,.14), rgba(124,77,255,.14)) !important;
  border-color: #7c4dff !important;
  color: #ce93d8 !important;
  box-shadow: 0 0 18px rgba(124,77,255,.25) !important;
}

/* ── Acumulado Destaque Card ───────────────────────── */
.fin-acum-destaque {
  background: linear-gradient(135deg, rgba(0,229,255,.06), rgba(105,240,174,.04));
  border: 1px solid rgba(0,229,255,.25);
  border-radius: 14px;
  padding: 1.4rem 1.6rem;
  backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.fin-acum-destaque-inner {
  display: flex;
  align-items: center;
  gap: 1.2rem;
}

.fin-acum-icon {
  font-size: 2.5rem;
  color: var(--cyan);
  text-shadow: 0 0 20px var(--cyan-glow);
  flex-shrink: 0;
}

.fin-acum-label {
  font-size: .85rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: rgba(176,190,197,.55);
}

.fin-acum-valor {
  font-family: var(--ff-h);
  font-size: 2rem;
  font-weight: 800;
  letter-spacing: .06em;
  display: block;
  margin-top: .2rem;
}

.fin-acum-chips {
  display: flex;
  gap: .6rem;
  flex-wrap: wrap;
}

.fin-acum-chip {
  padding: .3rem .85rem;
  border-radius: 20px;
  font-size: .8rem;
  font-family: var(--ff-b);
  letter-spacing: .04em;
}

.fin-chip-g { background: rgba(105,240,174,.1); border: 1px solid rgba(105,240,174,.25); color: var(--green); }
.fin-chip-r { background: rgba(255,82,82,.1);   border: 1px solid rgba(255,82,82,.25);  color: var(--red);   }
.fin-chip-b { background: rgba(0,229,255,.1);   border: 1px solid rgba(0,229,255,.25);  color: var(--cyan);  }

/* ── Raio-X Section ────────────────────────────────── */
.fin-raiox-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.2rem 1.4rem;
  backdrop-filter: blur(10px);
}

.fin-raiox-header {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.fin-section-title {
  font-family: var(--ff-b);
  font-size: 1rem;
  font-weight: 600;
  color: var(--white);
  letter-spacing: .04em;
}

.fin-raiox-sub {
  font-size: .8rem;
  color: rgba(176,190,197,.4);
}

.fin-raiox-scroll {
  overflow-x: auto;
  overflow-y: visible;
  border-radius: 8px;
  border: 1px solid rgba(0,229,255,.1);
}

.fin-raiox-table {
  border-collapse: collapse;
  width: 100%;
  min-width: 1200px;
  font-family: var(--ff-b);
  font-size: .8rem;
}

/* Cabeçalho */
.fin-rx-th-label {
  background: rgba(0,229,255,.08);
  color: var(--cyan);
  text-align: left;
  padding: .55rem .8rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  position: sticky;
  left: 0;
  z-index: 2;
  white-space: nowrap;
  min-width: 150px;
  border-right: 1px solid rgba(0,229,255,.12);
  border-bottom: 1px solid rgba(0,229,255,.15);
}

.fin-rx-th-mes {
  padding: .5rem .6rem;
  text-align: right;
  font-weight: 600;
  letter-spacing: .05em;
  text-transform: uppercase;
  border-bottom: 1px solid rgba(0,229,255,.15);
  white-space: nowrap;
  min-width: 90px;
}

.fin-rx-th-mes.fin-rx-past   { color: var(--white);  background: rgba(0,229,255,.04); }
.fin-rx-th-mes.fin-rx-future { color: rgba(176,190,197,.4); background: transparent; }

.fin-rx-th-anual {
  padding: .5rem .8rem;
  text-align: right;
  font-weight: 700;
  color: var(--cyan);
  background: rgba(0,229,255,.06);
  border-left: 1px solid rgba(0,229,255,.12);
  border-bottom: 1px solid rgba(0,229,255,.15);
  white-space: nowrap;
  min-width: 100px;
  letter-spacing: .04em;
}

/* Linhas de seção */
.fin-rx-section-header td {
  background: rgba(0,229,255,.05);
  color: var(--cyan);
  padding: .4rem .8rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  font-size: .75rem;
  border-top: 1px solid rgba(0,229,255,.1);
  border-bottom: 1px solid rgba(0,229,255,.08);
}

.fin-rx-sec-saida td { background: rgba(255,82,82,.04); color: rgba(255,82,82,.8); }
.fin-rx-sec-var td   { background: rgba(255,215,64,.04); color: rgba(255,215,64,.8); }
.fin-rx-sec-resumo td { background: rgba(124,77,255,.05); color: #b388ff; }

/* Nome da linha */
.fin-rx-nome {
  color: var(--text);
  padding: .45rem .8rem;
  white-space: nowrap;
  font-weight: 500;
  position: sticky;
  left: 0;
  background: var(--bg-card);
  z-index: 1;
  border-right: 1px solid rgba(0,229,255,.06);
  min-width: 150px;
}

.fin-rx-row:hover .fin-rx-nome { color: var(--white); }

/* Célula de valor */
.fin-rx-cell {
  padding: .45rem .6rem;
  text-align: right;
  color: var(--text);
  border-bottom: 1px solid rgba(0,229,255,.03);
  white-space: nowrap;
}

.fin-rx-cell.fin-rx-proj { color: rgba(176,190,197,.35); font-style: italic; }
.fin-rx-row:hover .fin-rx-cell { background: rgba(0,229,255,.03); color: var(--white); }
.fin-rx-row.fin-rx-entrada .fin-rx-cell { color: rgba(105,240,174,.8); }
.fin-rx-row.fin-rx-entrada:hover .fin-rx-cell { color: var(--green); }

.fin-rx-zero { color: rgba(176,190,197,.2); }

/* Célula anual */
.fin-rx-anual {
  padding: .45rem .8rem;
  text-align: right;
  color: var(--white);
  font-weight: 600;
  background: rgba(0,229,255,.03);
  border-left: 1px solid rgba(0,229,255,.06);
  white-space: nowrap;
}

/* Linhas de total */
.fin-rx-total-row { background: rgba(0,0,0,.3); }
.fin-rx-total-cell {
  padding: .5rem .6rem;
  text-align: right;
  font-weight: 700;
  font-size: .83rem;
  white-space: nowrap;
  border-top: 1px solid rgba(0,229,255,.1);
}

.fin-rx-total.fin-rx-total-entrada .fin-rx-nome  { color: var(--green); }
.fin-rx-total.fin-rx-total-entrada .fin-rx-total-cell { color: var(--green); }
.fin-rx-total.fin-rx-total-saida .fin-rx-nome    { color: var(--red); }
.fin-rx-total.fin-rx-total-saida .fin-rx-total-cell { color: var(--red); }

/* Saldo */
.fin-rx-saldo-row { background: rgba(0,0,0,.25); }
.fin-rx-saldo-cell {
  padding: .55rem .6rem;
  text-align: right;
  font-weight: 700;
  font-family: var(--ff-h);
  font-size: .82rem;
  white-space: nowrap;
  border-top: 2px solid rgba(0,229,255,.15);
}
.fin-rx-pos { color: var(--green); }
.fin-rx-neg { color: var(--red);   }
.fin-rx-saldo-row .fin-rx-nome { color: var(--white); font-weight: 700; font-family: var(--ff-h); font-size: .82rem; }

/* Acumulado */
.fin-rx-acum-row { background: rgba(0,229,255,.04); }
.fin-rx-acum-cell {
  padding: .5rem .6rem;
  text-align: right;
  font-weight: 700;
  white-space: nowrap;
}
.fin-rx-acum-pos { color: var(--cyan); text-shadow: 0 0 8px rgba(0,229,255,.4); }
.fin-rx-acum-neg { color: var(--red); }
.fin-rx-acum-row .fin-rx-nome { color: var(--cyan); font-weight: 700; }

/* ══════════════════════════════════════════════════════
   PROJETO 1 MILHÃO — Jarvis / Cyberpunk
══════════════════════════════════════════════════════ */

.fin-milhao-layout {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 1.4rem;
  min-height: 560px;
}

/* Painel de Inputs */
.fin-milhao-inputs {
  background: var(--bg-card);
  border: 1px solid rgba(124,77,255,.25);
  border-radius: 16px;
  padding: 1.4rem;
  backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}

.fin-milhao-inputs-header {
  display: flex;
  align-items: center;
  gap: .9rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(124,77,255,.2);
}

.fin-milhao-hicon {
  font-size: 2rem;
  color: #b388ff;
  text-shadow: 0 0 16px rgba(124,77,255,.6);
}

.fin-milhao-htitle {
  font-family: var(--ff-h);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--white);
  letter-spacing: .08em;
}

.fin-milhao-hsub {
  font-size: .78rem;
  color: rgba(176,190,197,.45);
  margin-top: .2rem;
}

.fin-milhao-field { display: flex; flex-direction: column; gap: .4rem; }

.fin-milhao-label {
  font-size: .78rem;
  letter-spacing: .07em;
  text-transform: uppercase;
  color: rgba(176,190,197,.5);
}

.fin-milhao-input {
  background: rgba(124,77,255,.06);
  border: 1px solid rgba(124,77,255,.25);
  border-radius: 8px;
  padding: .6rem .9rem;
  color: var(--white);
  font-family: var(--ff-h);
  font-size: 1rem;
  font-weight: 600;
  transition: border-color .2s, box-shadow .2s;
  width: 100%;
}

.fin-milhao-input:focus {
  outline: none;
  border-color: #b388ff;
  box-shadow: 0 0 0 3px rgba(124,77,255,.15);
}

.fin-milhao-hint {
  font-size: .73rem;
  color: rgba(176,190,197,.35);
}

.fin-milhao-taxa-row {
  display: flex;
  flex-direction: column;
  gap: .5rem;
}

.fin-milhao-presets, .fin-milhao-meta-row {
  display: flex;
  gap: .4rem;
  flex-wrap: wrap;
}

.fin-preset-btn, .fin-meta-btn {
  padding: .3rem .7rem;
  background: rgba(124,77,255,.06);
  border: 1px solid rgba(124,77,255,.2);
  border-radius: 6px;
  color: #b388ff;
  font-family: var(--ff-b);
  font-size: .8rem;
  cursor: pointer;
  transition: all .15s;
  white-space: nowrap;
}

.fin-preset-btn:hover, .fin-meta-btn:hover {
  background: rgba(124,77,255,.15);
  border-color: #7c4dff;
}

.fin-preset-btn.active, .fin-meta-btn.active {
  background: rgba(124,77,255,.2);
  border-color: #b388ff;
  color: #e1bee7;
  box-shadow: 0 0 8px rgba(124,77,255,.3);
}

.fin-milhao-calc-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .6rem;
  padding: .8rem 1.2rem;
  margin-top: .5rem;
  background: linear-gradient(135deg, rgba(124,77,255,.2), rgba(0,229,255,.1));
  border: 1px solid #7c4dff;
  border-radius: 10px;
  color: #e1bee7;
  font-family: var(--ff-h);
  font-size: .9rem;
  font-weight: 700;
  letter-spacing: .08em;
  cursor: pointer;
  transition: all .25s;
  box-shadow: 0 0 20px rgba(124,77,255,.2), inset 0 0 24px rgba(124,77,255,.05);
}

.fin-milhao-calc-btn:hover {
  background: linear-gradient(135deg, rgba(124,77,255,.35), rgba(0,229,255,.15));
  box-shadow: 0 0 36px rgba(124,77,255,.35), inset 0 0 30px rgba(124,77,255,.08);
  transform: translateY(-1px);
}

/* Painel Resultado Jarvis */
.fin-milhao-resultado {
  background: var(--bg-card);
  border: 1px solid rgba(0,229,255,.15);
  border-radius: 16px;
  padding: 1.6rem;
  backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.fin-milhao-resultado::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(0,229,255,.04), transparent 70%),
              radial-gradient(ellipse at 100% 100%, rgba(124,77,255,.04), transparent 60%);
  pointer-events: none;
}

/* Estado idle com orb animada */
.fin-milhao-idle {
  text-align: center;
  color: rgba(176,190,197,.4);
  font-size: .95rem;
  line-height: 1.8;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

.fin-milhao-orb {
  width: 80px; height: 80px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,229,255,.2), rgba(0,229,255,.02));
  border: 1px solid rgba(0,229,255,.2);
  box-shadow: 0 0 30px rgba(0,229,255,.1), inset 0 0 20px rgba(0,229,255,.05);
  animation: milOrbPulse 3s ease-in-out infinite;
}

@keyframes milOrbPulse {
  0%, 100% { box-shadow: 0 0 30px rgba(0,229,255,.1), inset 0 0 20px rgba(0,229,255,.05); transform: scale(1); }
  50%       { box-shadow: 0 0 50px rgba(0,229,255,.2), inset 0 0 30px rgba(0,229,255,.1); transform: scale(1.05); }
}

/* Display de resultado */
.fin-milhao-display {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  position: relative;
  z-index: 1;
}

.fin-milhao-meta-badge {
  display: inline-flex;
  align-self: flex-start;
  padding: .25rem .8rem;
  background: rgba(124,77,255,.15);
  border: 1px solid rgba(124,77,255,.3);
  border-radius: 20px;
  font-size: .78rem;
  font-weight: 600;
  color: #ce93d8;
  letter-spacing: .06em;
}

.fin-milhao-data-box, .fin-milhao-idade-box {
  display: flex;
  flex-direction: column;
  gap: .3rem;
}

.fin-milhao-data-label {
  font-size: .75rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: rgba(176,190,197,.4);
}

.fin-milhao-data-valor {
  font-family: var(--ff-h);
  font-size: 2.4rem;
  font-weight: 800;
  color: var(--cyan);
  text-shadow: 0 0 24px rgba(0,229,255,.5);
  letter-spacing: .06em;
  line-height: 1;
}

.fin-milhao-idade-valor {
  font-family: var(--ff-h);
  font-size: 1.5rem;
  font-weight: 700;
  color: #b388ff;
  text-shadow: 0 0 18px rgba(124,77,255,.5);
  letter-spacing: .06em;
}

/* Barra de progresso */
.fin-milhao-progress-wrap {
  display: flex;
  flex-direction: column;
  gap: .5rem;
}

.fin-milhao-progress-labels {
  display: flex;
  justify-content: space-between;
  font-size: .78rem;
  color: rgba(176,190,197,.45);
}

.fin-milhao-progress-bar {
  height: 10px;
  background: rgba(0,229,255,.06);
  border: 1px solid rgba(0,229,255,.12);
  border-radius: 5px;
  position: relative;
  overflow: hidden;
}

.fin-milhao-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(0,229,255,.6), var(--cyan));
  border-radius: 5px;
  transition: width .8s cubic-bezier(.25,.8,.25,1);
  position: relative;
}

.fin-milhao-progress-fill::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent);
  animation: progShimmer 2s infinite;
}

@keyframes progShimmer {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.fin-milhao-progress-glow {
  position: absolute;
  top: -4px; bottom: -4px;
  width: 2px;
  background: var(--cyan);
  box-shadow: 0 0 12px 4px var(--cyan-glow);
  border-radius: 1px;
  transform: translateX(-50%);
  transition: left .8s cubic-bezier(.25,.8,.25,1);
}

.fin-milhao-progress-pct {
  font-size: .78rem;
  color: var(--cyan);
  text-align: center;
  letter-spacing: .06em;
}

/* Stats grid */
.fin-milhao-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: .8rem;
}

.fin-milhao-stat {
  background: rgba(0,229,255,.04);
  border: 1px solid rgba(0,229,255,.1);
  border-radius: 8px;
  padding: .7rem .9rem;
  display: flex;
  flex-direction: column;
  gap: .25rem;
}

.fin-milhao-stat-label {
  font-size: .72rem;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: rgba(176,190,197,.4);
}

.fin-milhao-stat-val {
  font-family: var(--ff-h);
  font-size: .9rem;
  font-weight: 700;
  color: var(--white);
}

/* Mini chart */
.fin-milhao-chart-wrap {
  height: 110px;
  background: rgba(0,0,0,.15);
  border: 1px solid rgba(0,229,255,.08);
  border-radius: 8px;
  padding: .5rem;
}

/* Scrollbar estilo para Raio-X */
.fin-raiox-scroll::-webkit-scrollbar       { height: 5px; }
.fin-raiox-scroll::-webkit-scrollbar-track { background: rgba(0,229,255,.03); }
.fin-raiox-scroll::-webkit-scrollbar-thumb { background: rgba(0,229,255,.2); border-radius: 3px; }
.fin-raiox-scroll::-webkit-scrollbar-thumb:hover { background: rgba(0,229,255,.4); }
/* Responsive */
@media (max-width: 1100px) {
  .fin-milhao-layout { grid-template-columns: 1fr; }
  .fin-milhao-resultado { min-height: 450px; }
  .fin-milhao-stats { grid-template-columns: 1fr 1fr; }
}

/* ══════════════════════════════════════════════════════
   FÁBRICA DE CRIATIVOS — Cards de resultado
══════════════════════════════════════════════════════ */

.cf-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
}

.cf-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 0 18px rgba(0,229,255,.18);
}

.cf-card-img-wrap {
  position: relative;
  background: #020712;
}

.cf-card-img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
}

.cf-card-img-ph {
  height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .85rem;
  color: rgba(176,190,197,.6);
  background: radial-gradient(circle at 0 0, rgba(0,229,255,.25), transparent 55%);
}

.cf-card-badge {
  position: absolute;
  top: .5rem;
  left: .5rem;
  padding: .15rem .6rem;
  border-radius: 999px;
  font-family: var(--ff-h);
  font-size: .65rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  background: rgba(0,0,0,.75);
  color: var(--cyan);
  border: 1px solid rgba(0,229,255,.4);
}

.cf-card-body {
  padding: .75rem .9rem .9rem;
  display: flex;
  flex-direction: column;
  gap: .4rem;
}

.cf-card-headline {
  font-family: var(--ff-h);
  font-size: .95rem;
  font-weight: 800;
  letter-spacing: .02em;
  color: var(--cyan);
}

.cf-card-subheadline {
  font-size: .9rem;
  color: var(--text);
  line-height: 1.5;
}

.cf-card-actions {
  display: flex;
  gap: .5rem;
  margin-top: .65rem;
}

.cf-btn {
  flex: 1;
  height: 34px;
  border-radius: 8px;
  font-family: var(--ff-b);
  font-size: .8rem;
  font-weight: 600;
  letter-spacing: .05em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background .18s, border-color .18s, color .18s, box-shadow .18s;
}

.cf-btn-primary {
  border: 1px solid rgba(0,229,255,.4);
  background: rgba(0,229,255,.12);
  color: var(--cyan);
}

.cf-btn-primary:hover:not(:disabled) {
  background: rgba(0,229,255,.2);
  box-shadow: 0 0 14px rgba(0,229,255,.25);
}

.cf-btn-secondary {
  border: 1px solid rgba(176,190,197,.3);
  background: rgba(5,8,16,.9);
  color: rgba(176,190,197,.8);
}

.cf-btn-secondary:hover:not(:disabled) {
  border-color: var(--cyan);
  color: var(--cyan);
}

.cf-btn:disabled {
  opacity: .45;
  cursor: not-allowed;
}

/* ══════════════════════════════════════════════════════
   SITE ARCHITECT — Gerador de Landing Page
══════════════════════════════════════════════════════ */

.sa-layout {
  display: grid;
  grid-template-columns: 360px 1fr;
  height: 100vh;
  overflow: hidden;
}

.sa-sidebar {
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
  background: rgba(5,8,16,.96);
}

.sa-header {
  display: flex;
  align-items: flex-start;
  gap: .9rem;
  padding: 1.5rem 1.5rem 1.25rem;
  border-bottom: 1px solid var(--border);
  background: rgba(0,229,255,.025);
  flex-shrink: 0;
}

.sa-header-icon {
  font-size: 1.6rem;
  color: var(--cyan);
  text-shadow: 0 0 14px var(--cyan-glow);
  margin-top: .1rem;
}

.sa-title {
  font-family: var(--ff-h);
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: .1em;
  color: var(--white);
  text-transform: uppercase;
}

.sa-subtitle {
  font-size: .8rem;
  color: rgba(176,190,197,.55);
  margin-top: .3rem;
  line-height: 1.4;
}

.sa-form {
  padding: 1.2rem 1.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.sa-group-label {
  font-family: var(--ff-h);
  font-size: .62rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--cyan);
  opacity: .8;
  padding-top: .5rem;
  border-top: 1px solid rgba(0,229,255,.1);
}

.sa-form > .sa-group-label:first-child {
  border-top: none;
  padding-top: 0;
}

.sa-field {
  display: flex;
  flex-direction: column;
  gap: .4rem;
}

.sa-label {
  font-size: .7rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(176,190,197,.7);
}

.sa-input,
.sa-textarea {
  width: 100%;
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(0,229,255,.18);
  border-radius: 8px;
  padding: .55rem .75rem;
  color: var(--white);
  font-family: var(--ff-b);
  font-size: .9rem;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
}

.sa-input:focus,
.sa-textarea:focus {
  border-color: var(--cyan);
  box-shadow: 0 0 0 2px rgba(0,229,255,.12);
}

.sa-input::placeholder,
.sa-textarea::placeholder {
  color: rgba(176,190,197,.35);
}

.sa-textarea {
  resize: vertical;
  min-height: 70px;
}

.sa-hint {
  font-size: .75rem;
  color: rgba(176,190,197,.45);
}

.sa-upload-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0,1fr));
  gap: .8rem;
}

.sa-upload-card {
  display: flex;
  flex-direction: column;
  gap: .35rem;
}

.sa-dropzone {
  border: 1px dashed rgba(0,229,255,.2);
  border-radius: 10px;
  padding: .6rem;
  min-height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  background: rgba(255,255,255,.02);
  position: relative;
  overflow: hidden;
  transition: border-color .2s, background .2s;
}

.sa-dropzone:hover,
.sa-dropzone.sa-dragover {
  border-color: var(--cyan);
  background: rgba(0,229,255,.05);
}

.sa-file-input {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
}

.sa-drop-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .3rem;
  color: rgba(176,190,197,.5);
  font-size: .8rem;
  pointer-events: none;
}

.sa-drop-placeholder span {
  font-size: 1.2rem;
}

.sa-preview {
  width: 100%;
  border-radius: 8px;
  object-fit: cover;
}

.sa-preview-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0,1fr));
  gap: .3rem;
  width: 100%;
}

.sa-preview-grid img {
  width: 100%;
  height: 52px;
  object-fit: cover;
  border-radius: 6px;
}

.sa-actions {
  display: grid;
  grid-template-columns: minmax(0,1fr) auto;
  gap: .6rem;
  margin-top: .25rem;
}

.sa-btn-primary {
  height: 44px;
  border-radius: 10px;
  border: none;
  background: linear-gradient(135deg, #00e5ff 0%, #00b8d4 40%, #006dd9 100%);
  color: #020d18;
  font-family: var(--ff-b);
  font-size: .95rem;
  font-weight: 700;
  letter-spacing: .06em;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .55rem;
  box-shadow: 0 0 22px rgba(0,229,255,.38), 0 4px 16px rgba(0,0,0,.45);
  transition: opacity .2s, transform .15s, box-shadow .2s;
}

.sa-btn-primary:hover {
  opacity: .95;
  transform: translateY(-1px);
  box-shadow: 0 0 30px rgba(0,229,255,.55), 0 6px 20px rgba(0,0,0,.45);
}

.sa-btn-primary:disabled {
  opacity: .45;
  cursor: not-allowed;
  box-shadow: none;
  transform: none;
}

.sa-btn-icon {
  font-size: 1rem;
}

.sa-btn-ghost {
  height: 44px;
  border-radius: 10px;
  border: 1px solid rgba(176,190,197,.35);
  background: transparent;
  color: rgba(176,190,197,.8);
  font-family: var(--ff-b);
  font-size: .85rem;
  cursor: pointer;
  padding: 0 1rem;
  transition: color .2s, border-color .2s, background .2s;
}

.sa-btn-ghost:hover {
  border-color: var(--cyan);
  color: var(--cyan);
  background: rgba(0,229,255,.06);
}

.sa-status {
  margin-top: .25rem;
  font-size: .8rem;
  padding: .4rem .65rem;
  border-radius: 6px;
  display: none;
}

.sa-status.visible { display: block; }
.sa-status-ok { background: rgba(105,240,174,.12); color: var(--green); border: 1px solid rgba(105,240,174,.25); }
.sa-status-error { background: rgba(255,82,82,.12); color: var(--red); border: 1px solid rgba(255,82,82,.25); }
.sa-status-loading { background: rgba(0,229,255,.12); color: var(--cyan); border: 1px solid rgba(0,229,255,.25); }

.sa-main {
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.sa-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 1.5rem .75rem;
  border-bottom: 1px solid var(--border);
  background: rgba(7,11,18,.96);
}

.sa-toolbar-label {
  font-family: var(--ff-h);
  font-size: .72rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(176,190,197,.6);
}

.sa-toolbar-right {
  display: flex;
  align-items: center;
  gap: .6rem;
}

.sa-chip-toggle {
  padding: .3rem .7rem;
  border-radius: 999px;
  border: 1px solid rgba(0,229,255,.25);
  background: transparent;
  color: rgba(176,190,197,.7);
  font-size: .78rem;
  font-family: var(--ff-b);
  cursor: pointer;
  transition: all .2s;
}

.sa-chip-toggle.sa-active {
  background: rgba(0,229,255,.16);
  color: var(--cyan);
  border-color: var(--cyan);
  box-shadow: 0 0 12px rgba(0,229,255,.25);
}

.sa-btn-publish {
  padding: .4rem 1.2rem;
  border-radius: 999px;
  border: 1px solid rgba(0,229,255,.4);
  background: rgba(0,229,255,.08);
  color: var(--cyan);
  font-family: var(--ff-h);
  font-size: .8rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all .2s;
}

.sa-btn-publish:hover {
  background: rgba(0,229,255,.18);
  box-shadow: 0 0 16px rgba(0,229,255,.35);
}

.sa-preview-area {
  flex: 1;
  min-height: 0;
  padding: 1rem 1.5rem .5rem;
  display: flex;
  flex-direction: column;
  gap: .75rem;
}

.sa-iframe {
  flex: 1;
  min-height: 0;
  width: 100%;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: #0b101b;
}

.sa-html-view {
  flex: 1;
  min-height: 0;
  padding: 1rem 1.2rem;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: #02030a;
  color: var(--white);
  font-family: "JetBrains Mono", monospace;
  font-size: .8rem;
  overflow: auto;
}

.sa-chat {
  border-top: 1px solid var(--border);
  padding: .75rem 1.5rem 1rem;
  background: rgba(7,11,18,.98);
}

.sa-chat-header {
  display: flex;
  flex-direction: column;
  gap: .2rem;
  margin-bottom: .5rem;
}

.sa-chat-title {
  font-family: var(--ff-h);
  font-size: .75rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(176,190,197,.7);
}

.sa-chat-hint {
  font-size: .78rem;
  color: rgba(176,190,197,.45);
}

.sa-chat-body {
  max-height: 130px;
  overflow-y: auto;
  padding: .4rem 0 .6rem;
  display: flex;
  flex-direction: column;
  gap: .35rem;
  font-size: .86rem;
}

.sa-chat-msg {
  display: inline-flex;
  max-width: 100%;
  padding: .4rem .65rem;
  border-radius: 8px;
  font-size: .86rem;
}

.sa-chat-msg-user {
  align-self: flex-end;
  background: rgba(0,229,255,.16);
  color: var(--white);
}

.sa-chat-msg-ai {
  align-self: flex-start;
  background: rgba(255,255,255,.04);
  color: rgba(176,190,197,.9);
}

.sa-chat-form {
  display: grid;
  grid-template-columns: minmax(0,1fr) auto;
  gap: .5rem;
}

.sa-chat-input {
  background: rgba(255,255,255,.03);
  border-radius: 999px;
  border: 1px solid rgba(0,229,255,.2);
  padding: .55rem .9rem;
  color: var(--white);
  font-family: var(--ff-b);
  font-size: .9rem;
  outline: none;
}

.sa-chat-input:focus {
  border-color: var(--cyan);
  box-shadow: 0 0 0 2px rgba(0,229,255,.14);
}

.sa-chat-input::placeholder {
  color: rgba(176,190,197,.35);
}

.sa-chat-send {
  padding: .45rem 1.2rem;
  border-radius: 999px;
  border: 1px solid rgba(0,229,255,.4);
  background: rgba(0,229,255,.08);
  color: var(--cyan);
  font-family: var(--ff-b);
  font-size: .85rem;
  cursor: pointer;
  transition: all .2s;
}

.sa-chat-send:hover {
  background: rgba(0,229,255,.18);
}

@media (max-width: 960px) {
  .sa-layout {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    height: auto;
  }
  .sa-sidebar {
    max-height: 360px;
  }
}

